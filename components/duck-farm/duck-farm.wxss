/* ==============================
   Farm card & layout
   ============================== */

.farm-container {
  background: #fff;
  border-radius: 24rpx;
  margin-bottom: 30rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.08);
}

.farm-title-row {
  display: flex;
  align-items: center;
  padding: 24rpx 28rpx 0;
}

.farm-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.farm-ground {
  height: 240rpx;
  overflow: hidden;
  width: 100%;
  box-sizing: border-box;
}

.farm-grass {
  position: relative;
  display: inline-flex;
  flex-direction: row;
  flex-wrap: nowrap;
  align-items: flex-end;
  justify-content: flex-start;
  box-sizing: border-box;
  min-height: 200rpx;
  min-width: 100%;
  padding: 20rpx;
  padding-bottom: 28rpx;
  background: linear-gradient(180deg, #a5d6a7 0%, #81c784 50%, #66bb6a 100%);
}

/* Bottom pixel-style grass strip */
.farm-grass::after {
  content: '';
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  height: 12rpx;
  pointer-events: none;
  background: repeating-linear-gradient(
    90deg,
    #43a047 0rpx,
    #43a047 6rpx,
    #2e7d32 6rpx,
    #2e7d32 10rpx,
    #388e3c 10rpx,
    #388e3c 14rpx,
    #1b5e20 14rpx,
    #1b5e20 16rpx
  );
  opacity: 0.85;
}

.farm-duck-slot {
  position: relative;
  display: inline-flex;
  align-items: flex-end;
  justify-content: center;
  flex-shrink: 0;
  margin-right: 20rpx;
  padding-top: 20rpx;
  transform-origin: 50% 100%;
  animation: idle-wobble 2s ease-in-out infinite;
}

.farm-duck-slot:last-child {
  margin-right: 20rpx;
}

/* ==============================
   Mini pixel duck (8rpx grid, half of duck-animation)
   ============================== */

.pixel-duck-mini {
  width: 8rpx;
  height: 8rpx;
  overflow: visible;
  position: relative;
}

/*
  Normal duck 8x7 grid (same layout as .pixel-duck.normal)
*/
.pixel-duck-mini.normal {
  background: #ffd600;
  box-shadow:
    16rpx 0 0 #ffd600,
    24rpx 0 0 #ffd600,
    32rpx 0 0 #ffd600,
    8rpx 8rpx 0 #ffd600,
    16rpx 8rpx 0 #ffd600,
    24rpx 8rpx 0 #ffd600,
    32rpx 8rpx 0 #ffd600,
    40rpx 8rpx 0 #ffd600,
    8rpx 16rpx 0 #ffd600,
    16rpx 16rpx 0 #333333,
    24rpx 16rpx 0 #ffd600,
    32rpx 16rpx 0 #ffd600,
    40rpx 16rpx 0 #ffd600,
    48rpx 16rpx 0 #ff8f00,
    16rpx 24rpx 0 #ffd600,
    24rpx 24rpx 0 #ffd600,
    32rpx 24rpx 0 #ffd600,
    40rpx 24rpx 0 #ffd600,
    48rpx 24rpx 0 #ff8f00,
    0rpx 32rpx 0 #ffd600,
    8rpx 32rpx 0 #ffd600,
    16rpx 32rpx 0 #ffd600,
    24rpx 32rpx 0 #ffd600,
    32rpx 32rpx 0 #ffd600,
    40rpx 32rpx 0 #ffd600,
    8rpx 40rpx 0 #ffd600,
    16rpx 40rpx 0 #ffd600,
    32rpx 40rpx 0 #ffd600,
    40rpx 40rpx 0 #ffd600,
    8rpx 48rpx 0 #ff8f00,
    16rpx 48rpx 0 #ff8f00,
    32rpx 48rpx 0 #ff8f00,
    40rpx 48rpx 0 #ff8f00;
}

.pixel-duck-mini.golden {
  background: #ffd700;
  filter: drop-shadow(0 0 4rpx rgba(255, 215, 0, 0.8));
  box-shadow:
    16rpx 0 0 #ffd700,
    24rpx 0 0 #ffd700,
    32rpx 0 0 #ffd700,
    8rpx 8rpx 0 #ffd700,
    16rpx 8rpx 0 #ffd700,
    24rpx 8rpx 0 #ffa000,
    32rpx 8rpx 0 #ffd700,
    40rpx 8rpx 0 #ffd700,
    8rpx 16rpx 0 #ffd700,
    16rpx 16rpx 0 #5d4037,
    24rpx 16rpx 0 #ffd700,
    32rpx 16rpx 0 #ffd700,
    40rpx 16rpx 0 #ffd700,
    48rpx 16rpx 0 #ffa000,
    16rpx 24rpx 0 #ffd700,
    24rpx 24rpx 0 #ffd700,
    32rpx 24rpx 0 #ffd700,
    40rpx 24rpx 0 #ffd700,
    48rpx 24rpx 0 #ffa000,
    0rpx 32rpx 0 #ffd700,
    8rpx 32rpx 0 #ffa000,
    16rpx 32rpx 0 #ffd700,
    24rpx 32rpx 0 #ffd700,
    32rpx 32rpx 0 #ffa000,
    40rpx 32rpx 0 #ffd700,
    8rpx 40rpx 0 #ffd700,
    16rpx 40rpx 0 #ffd700,
    32rpx 40rpx 0 #ffd700,
    40rpx 40rpx 0 #ffd700,
    8rpx 48rpx 0 #ffa000,
    16rpx 48rpx 0 #ffa000,
    32rpx 48rpx 0 #ffa000,
    40rpx 48rpx 0 #ffa000;
}

/*
  Mini crown (5x3), same pattern as .pixel-crown
*/
.pixel-crown-mini {
  width: 8rpx;
  height: 8rpx;
  background: #ffd700;
  position: absolute;
  top: -12rpx;
  left: 50%;
  margin-left: -12rpx;
  box-shadow:
    0rpx 0 0 #ffd700,
    16rpx 0 0 #ffd700,
    32rpx 0 0 #ffd700,
    0rpx 8rpx 0 #ffd700,
    8rpx 8rpx 0 #ffd700,
    16rpx 8rpx 0 #ffd700,
    24rpx 8rpx 0 #ffd700,
    32rpx 8rpx 0 #ffd700,
    0rpx 16rpx 0 #ffd700,
    8rpx 16rpx 0 #ffd700,
    16rpx 16rpx 0 #ff0000,
    24rpx 16rpx 0 #ffd700,
    32rpx 16rpx 0 #ffd700;
}

@keyframes idle-wobble {
  0%,
  100% {
    transform: rotate(-3deg);
  }

  50% {
    transform: rotate(3deg);
  }
}

/* ==============================
   Stats & empty state
   ============================== */

.farm-stats {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  align-items: center;
  padding: 12rpx 28rpx 20rpx;
  gap: 0;
}

.farm-stat {
  font-size: 24rpx;
  color: #888;
}

.golden-stat {
  color: #ffa000;
  font-weight: 600;
}

.farm-stat-divider {
  color: #ddd;
  margin: 0 12rpx;
  font-size: 24rpx;
}

.farm-empty {
  padding: 40rpx;
  text-align: center;
  background: #fff;
  border-radius: 24rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.06);
}

.farm-empty-text {
  font-size: 26rpx;
  color: #bbb;
}
