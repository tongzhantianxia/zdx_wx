/* ==============================
   Farm card & layout
   ============================== */

.farm-container {
  background: #fff;
  border-radius: 24rpx;
  margin-bottom: 30rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.08);
}

.farm-title-row {
  display: flex;
  align-items: center;
  padding: 24rpx 28rpx 0;
}

.farm-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.farm-ground {
  height: 240rpx;
  overflow: hidden;
  width: 100%;
  box-sizing: border-box;
}

.farm-grass {
  position: relative;
  display: inline-flex;
  flex-direction: row;
  flex-wrap: nowrap;
  align-items: flex-end;
  justify-content: flex-start;
  box-sizing: border-box;
  min-height: 200rpx;
  min-width: 100%;
  padding: 20rpx;
  padding-bottom: 28rpx;
  background: linear-gradient(180deg, #a5d6a7 0%, #81c784 50%, #66bb6a 100%);
}

/* Bottom pixel-style grass strip */
.farm-grass::after {
  content: '';
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  height: 12rpx;
  pointer-events: none;
  background: repeating-linear-gradient(
    90deg,
    #43a047 0rpx,
    #43a047 6rpx,
    #2e7d32 6rpx,
    #2e7d32 10rpx,
    #388e3c 10rpx,
    #388e3c 14rpx,
    #1b5e20 14rpx,
    #1b5e20 16rpx
  );
  opacity: 0.85;
}

.farm-duck-slot {
  position: relative;
  display: inline-flex;
  align-items: flex-end;
  justify-content: center;
  flex-shrink: 0;
  margin-right: 20rpx;
  padding-top: 20rpx;
  transform-origin: 50% 100%;
  animation: idle-wobble 2s ease-in-out infinite;
}

.farm-duck-slot:last-child {
  margin-right: 20rpx;
}

/* ==============================
   Mini cartoon duck (rounded, ~65rpx tall)
   ============================== */

.cartoon-duck-mini {
  position: relative;
  width: 50rpx;
  height: 65rpx;
  flex-shrink: 0;
}

.mini-body {
  width: 44rpx;
  height: 36rpx;
  background: #ffd600;
  border-radius: 50%;
  position: absolute;
  bottom: 0;
  left: 3rpx;
  z-index: 1;
}

.mini-head {
  width: 32rpx;
  height: 28rpx;
  background: #ffd600;
  border-radius: 50%;
  position: absolute;
  top: 0;
  left: 9rpx;
  z-index: 2;
  overflow: visible;
}

.mini-head::before,
.mini-head::after {
  content: '';
  position: absolute;
  width: 7rpx;
  height: 5rpx;
  background: rgba(255, 138, 128, 0.55);
  border-radius: 50%;
  top: 14rpx;
}

.mini-head::before {
  left: 2rpx;
}

.mini-head::after {
  right: 14rpx;
}

.mini-eye {
  width: 6rpx;
  height: 7rpx;
  background: #333;
  border-radius: 50%;
  position: absolute;
  top: 9rpx;
  right: 6rpx;
  z-index: 1;
}

.mini-eye::after {
  content: '';
  position: absolute;
  width: 2rpx;
  height: 2rpx;
  background: #fff;
  border-radius: 50%;
  top: 1rpx;
  right: 1rpx;
}

.mini-beak {
  width: 10rpx;
  height: 6rpx;
  background: #ff8f00;
  border-radius: 0 50% 50% 0;
  position: absolute;
  top: 12rpx;
  right: -4rpx;
  z-index: 1;
}

.cartoon-duck-mini.golden .mini-body,
.cartoon-duck-mini.golden .mini-head {
  background: #ffd700;
}

.cartoon-duck-mini.golden {
  filter: drop-shadow(0 0 6rpx rgba(255, 215, 0, 0.6));
}

.cartoon-duck-mini.golden .mini-head::before,
.cartoon-duck-mini.golden .mini-head::after {
  background: rgba(255, 183, 77, 0.5);
}

/* Gold band + three small peaks (triangle/rectangle feel) */
.mini-crown {
  position: absolute;
  top: -10rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 26rpx;
  height: 11rpx;
  background: #ffd700;
  z-index: 3;
  clip-path: polygon(
    0% 100%,
    10% 40%,
    22% 100%,
    36% 45%,
    50% 12%,
    64% 45%,
    78% 100%,
    90% 40%,
    100% 100%
  );
}


@keyframes idle-wobble {
  0%,
  100% {
    transform: rotate(-3deg);
  }

  50% {
    transform: rotate(3deg);
  }
}

/* ==============================
   Stats & empty state
   ============================== */

.farm-stats {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  align-items: center;
  padding: 12rpx 28rpx 20rpx;
  gap: 0;
}

.farm-stat {
  font-size: 24rpx;
  color: #888;
}

.golden-stat {
  color: #ffa000;
  font-weight: 600;
}

.farm-stat-divider {
  color: #ddd;
  margin: 0 12rpx;
  font-size: 24rpx;
}

.farm-empty {
  padding: 40rpx;
  text-align: center;
  background: #fff;
  border-radius: 24rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.06);
}

.farm-empty-text {
  font-size: 26rpx;
  color: #bbb;
}
