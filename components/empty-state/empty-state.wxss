/* 空状态组件样式 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 40rpx;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 24rpx;
  opacity: 0.6;
}

.empty-text {
  font-size: 32rpx;
  color: #909399;
  margin-bottom: 12rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: #C0C4CC;
  margin-bottom: 32rpx;
}

.empty-btn {
  padding: 20rpx 48rpx;
  background: linear-gradient(135deg, #4A90E2 0%, #6BA3E8 100%);
  color: #FFFFFF;
  font-size: 28rpx;
  border-radius: 44rpx;
  border: none;
}

.empty-btn::after {
  border: none;
}
