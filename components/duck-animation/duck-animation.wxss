/* ==============================
   Overlay & Container
   ============================== */

.duck-anim-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 999;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(0, 0, 0, 0.15);
}

.duck-anim-overlay.golden_hatch {
  background: rgba(0, 0, 0, 0.6);
  animation: overlayDarken 0.5s ease;
}

.duck-anim-overlay.golden_death {
  background: rgba(0, 0, 0, 0.4);
}

.anim-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
}

/* ==============================
   Pixel Duck (box-shadow technique)
   8x7 grid, each pixel = 16rpx
   ============================== */

.pixel-duck {
  width: 16rpx;
  height: 16rpx;
  overflow: visible;
  position: relative;
}

/*
  Normal duck layout (8 wide x 7 tall):
  Row 0:     . . # # # . . .
  Row 1:     . # # # # # . .
  Row 2:     . # E # # # B .
  Row 3:     . . # # # # B .
  Row 4:     # # # # # # . .
  Row 5:     . # # . # # . .
  Row 6:     . F F . F F . .
  # = body (#FFD600), E = eye (#333), B = beak (#FF8F00), F = feet (#FF8F00)
*/
.pixel-duck.normal {
  background: #FFD600;
  box-shadow:
    /* Row 0: head top */
    32rpx 0 0 #FFD600,
    48rpx 0 0 #FFD600,
    64rpx 0 0 #FFD600,
    /* Row 1: head */
    16rpx 16rpx 0 #FFD600,
    32rpx 16rpx 0 #FFD600,
    48rpx 16rpx 0 #FFD600,
    64rpx 16rpx 0 #FFD600,
    80rpx 16rpx 0 #FFD600,
    /* Row 2: head with eye + beak */
    16rpx 32rpx 0 #FFD600,
    32rpx 32rpx 0 #333333,
    48rpx 32rpx 0 #FFD600,
    64rpx 32rpx 0 #FFD600,
    80rpx 32rpx 0 #FFD600,
    96rpx 32rpx 0 #FF8F00,
    /* Row 3: neck/beak */
    32rpx 48rpx 0 #FFD600,
    48rpx 48rpx 0 #FFD600,
    64rpx 48rpx 0 #FFD600,
    80rpx 48rpx 0 #FFD600,
    96rpx 48rpx 0 #FF8F00,
    /* Row 4: body */
    0rpx 64rpx 0 #FFD600,
    16rpx 64rpx 0 #FFD600,
    32rpx 64rpx 0 #FFD600,
    48rpx 64rpx 0 #FFD600,
    64rpx 64rpx 0 #FFD600,
    80rpx 64rpx 0 #FFD600,
    /* Row 5: lower body */
    16rpx 80rpx 0 #FFD600,
    32rpx 80rpx 0 #FFD600,
    64rpx 80rpx 0 #FFD600,
    80rpx 80rpx 0 #FFD600,
    /* Row 6: feet */
    16rpx 96rpx 0 #FF8F00,
    32rpx 96rpx 0 #FF8F00,
    64rpx 96rpx 0 #FF8F00,
    80rpx 96rpx 0 #FF8F00;
}

.pixel-duck.golden {
  background: #FFD700;
  filter: drop-shadow(0 0 8rpx rgba(255, 215, 0, 0.8));
  box-shadow:
    /* Row 0 */
    32rpx 0 0 #FFD700,
    48rpx 0 0 #FFD700,
    64rpx 0 0 #FFD700,
    /* Row 1 */
    16rpx 16rpx 0 #FFD700,
    32rpx 16rpx 0 #FFD700,
    48rpx 16rpx 0 #FFA000,
    64rpx 16rpx 0 #FFD700,
    80rpx 16rpx 0 #FFD700,
    /* Row 2 */
    16rpx 32rpx 0 #FFD700,
    32rpx 32rpx 0 #5D4037,
    48rpx 32rpx 0 #FFD700,
    64rpx 32rpx 0 #FFD700,
    80rpx 32rpx 0 #FFD700,
    96rpx 32rpx 0 #FFA000,
    /* Row 3 */
    32rpx 48rpx 0 #FFD700,
    48rpx 48rpx 0 #FFD700,
    64rpx 48rpx 0 #FFD700,
    80rpx 48rpx 0 #FFD700,
    96rpx 48rpx 0 #FFA000,
    /* Row 4 */
    0rpx 64rpx 0 #FFD700,
    16rpx 64rpx 0 #FFA000,
    32rpx 64rpx 0 #FFD700,
    48rpx 64rpx 0 #FFD700,
    64rpx 64rpx 0 #FFA000,
    80rpx 64rpx 0 #FFD700,
    /* Row 5 */
    16rpx 80rpx 0 #FFD700,
    32rpx 80rpx 0 #FFD700,
    64rpx 80rpx 0 #FFD700,
    80rpx 80rpx 0 #FFD700,
    /* Row 6 */
    16rpx 96rpx 0 #FFA000,
    32rpx 96rpx 0 #FFA000,
    64rpx 96rpx 0 #FFA000,
    80rpx 96rpx 0 #FFA000;
}

/* ==============================
   Pixel Egg (box-shadow, ~6x8 oval)
   ============================== */

/*
  Egg layout (6 wide x 8 tall):
  Row 0:   . . # # . .
  Row 1:   . # # # # .
  Row 2:   # # # # # #
  Row 3:   # # # # # #
  Row 4:   # # # # # #
  Row 5:   # # # # # #
  Row 6:   . # # # # .
  Row 7:   . . # # . .
*/
.pixel-egg {
  width: 16rpx;
  height: 16rpx;
  background: #FFF8E1;
  box-shadow:
    /* Row 0 */
    32rpx 0 0 #FFFFFF,
    48rpx 0 0 #FFFFFF,
    /* Row 1 */
    16rpx 16rpx 0 #FFFFFF,
    32rpx 16rpx 0 #FFF8E1,
    48rpx 16rpx 0 #FFF8E1,
    64rpx 16rpx 0 #FFFFFF,
    /* Row 2 */
    0rpx 32rpx 0 #FFFFFF,
    16rpx 32rpx 0 #FFF8E1,
    32rpx 32rpx 0 #FFF8E1,
    48rpx 32rpx 0 #FFF8E1,
    64rpx 32rpx 0 #FFF8E1,
    80rpx 32rpx 0 #FFFFFF,
    /* Row 3 */
    0rpx 48rpx 0 #FFFFFF,
    16rpx 48rpx 0 #FFF8E1,
    32rpx 48rpx 0 #FFF8E1,
    48rpx 48rpx 0 #FFF8E1,
    64rpx 48rpx 0 #FFF8E1,
    80rpx 48rpx 0 #FFFFFF,
    /* Row 4 */
    0rpx 64rpx 0 #F5F5DC,
    16rpx 64rpx 0 #FFF8E1,
    32rpx 64rpx 0 #FFF8E1,
    48rpx 64rpx 0 #FFF8E1,
    64rpx 64rpx 0 #FFF8E1,
    80rpx 64rpx 0 #F5F5DC,
    /* Row 5 */
    0rpx 80rpx 0 #F5F5DC,
    16rpx 80rpx 0 #F5F5DC,
    32rpx 80rpx 0 #FFF8E1,
    48rpx 80rpx 0 #FFF8E1,
    64rpx 80rpx 0 #F5F5DC,
    80rpx 80rpx 0 #F5F5DC,
    /* Row 6 */
    16rpx 96rpx 0 #F5F5DC,
    32rpx 96rpx 0 #F5F5DC,
    48rpx 96rpx 0 #F5F5DC,
    64rpx 96rpx 0 #F5F5DC,
    /* Row 7 */
    32rpx 112rpx 0 #F5F5DC,
    48rpx 112rpx 0 #F5F5DC;
}

.pixel-egg.golden {
  background: #FFD700;
  filter: drop-shadow(0 0 10rpx rgba(255, 215, 0, 0.9));
  box-shadow:
    /* Row 0 */
    32rpx 0 0 #FFE44D,
    48rpx 0 0 #FFE44D,
    /* Row 1 */
    16rpx 16rpx 0 #FFE44D,
    32rpx 16rpx 0 #FFD700,
    48rpx 16rpx 0 #FFD700,
    64rpx 16rpx 0 #FFE44D,
    /* Row 2 */
    0rpx 32rpx 0 #FFE44D,
    16rpx 32rpx 0 #FFD700,
    32rpx 32rpx 0 #FFC107,
    48rpx 32rpx 0 #FFD700,
    64rpx 32rpx 0 #FFD700,
    80rpx 32rpx 0 #FFE44D,
    /* Row 3 */
    0rpx 48rpx 0 #FFE44D,
    16rpx 48rpx 0 #FFD700,
    32rpx 48rpx 0 #FFD700,
    48rpx 48rpx 0 #FFC107,
    64rpx 48rpx 0 #FFD700,
    80rpx 48rpx 0 #FFE44D,
    /* Row 4 */
    0rpx 64rpx 0 #FFC107,
    16rpx 64rpx 0 #FFD700,
    32rpx 64rpx 0 #FFD700,
    48rpx 64rpx 0 #FFD700,
    64rpx 64rpx 0 #FFD700,
    80rpx 64rpx 0 #FFC107,
    /* Row 5 */
    0rpx 80rpx 0 #FFA000,
    16rpx 80rpx 0 #FFC107,
    32rpx 80rpx 0 #FFD700,
    48rpx 80rpx 0 #FFD700,
    64rpx 80rpx 0 #FFC107,
    80rpx 80rpx 0 #FFA000,
    /* Row 6 */
    16rpx 96rpx 0 #FFA000,
    32rpx 96rpx 0 #FFC107,
    48rpx 96rpx 0 #FFC107,
    64rpx 96rpx 0 #FFA000,
    /* Row 7 */
    32rpx 112rpx 0 #FFA000,
    48rpx 112rpx 0 #FFA000;
}

/* ==============================
   Pixel Crown (5x3, gold + red gem)
   ============================== */

/*
  Crown layout (5 wide x 3 tall):
  Row 0:  # . # . #
  Row 1:  # # # # #
  Row 2:  # # R # #
  # = gold (#FFD700), R = red gem (#FF0000)
*/
.pixel-crown {
  width: 16rpx;
  height: 16rpx;
  background: #FFD700;
  position: absolute;
  top: -52rpx;
  left: 50%;
  margin-left: -24rpx;
  box-shadow:
    /* Row 0: three points */
    0rpx 0 0 #FFD700,
    32rpx 0 0 #FFD700,
    64rpx 0 0 #FFD700,
    /* Row 1: full band */
    0rpx 16rpx 0 #FFD700,
    16rpx 16rpx 0 #FFD700,
    32rpx 16rpx 0 #FFD700,
    48rpx 16rpx 0 #FFD700,
    64rpx 16rpx 0 #FFD700,
    /* Row 2: band with red gem */
    0rpx 32rpx 0 #FFD700,
    16rpx 32rpx 0 #FFD700,
    32rpx 32rpx 0 #FF0000,
    48rpx 32rpx 0 #FFD700,
    64rpx 32rpx 0 #FFD700;
}

/* ==============================
   Normal Hatch Animations (~1s)
   ============================== */

.egg-wrap {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
}

.normal-egg-anim {
  animation: eggBounceIn 0.3s ease-out, eggCrack 0.4s ease 0.3s forwards;
}

.duck-appear {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
}

.normal-duck-appear {
  opacity: 0;
  animation: duckPopOut 0.3s ease 0.7s forwards;
}

@keyframes eggBounceIn {
  0% {
    transform: scale(0) translateY(-60rpx);
    opacity: 0;
  }
  60% {
    transform: scale(1.1) translateY(10rpx);
    opacity: 1;
  }
  80% {
    transform: scale(0.95) translateY(-5rpx);
  }
  100% {
    transform: scale(1) translateY(0);
    opacity: 1;
  }
}

@keyframes eggCrack {
  0% {
    transform: scale(1) rotate(0deg);
    opacity: 1;
  }
  20% {
    transform: scale(1.05) rotate(-3deg);
  }
  40% {
    transform: scale(1.05) rotate(3deg);
  }
  60% {
    transform: scale(1.1) rotate(-2deg);
  }
  80% {
    transform: scale(0.5) rotate(5deg);
    opacity: 0.5;
  }
  100% {
    transform: scale(0) rotate(10deg);
    opacity: 0;
  }
}

@keyframes duckPopOut {
  0% {
    opacity: 0;
    transform: translate(-50%, -50%) scale(0.5);
  }
  60% {
    opacity: 1;
    transform: translate(-50%, -50%) scale(1.1);
  }
  80% {
    transform: translate(-50%, -50%) scale(0.95) translateY(-10rpx);
  }
  100% {
    opacity: 1;
    transform: translate(-50%, -50%) scale(1) translateY(0);
  }
}

/* ==============================
   Normal Death Animations (~1s)
   ============================== */

.duck-shatter {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
}

.normal-shatter {
  animation: duckFadeIn 0.2s ease;
}

.shattering {
  animation: shatterOut 0.5s ease 0.2s forwards;
}

.pixel-fragment {
  position: absolute;
  width: 16rpx;
  height: 16rpx;
  background: #999999;
  opacity: 1;
}

.frag-1 { animation: fragmentFly1 0.8s ease-out 0.2s forwards; }
.frag-2 { animation: fragmentFly2 0.8s ease-out 0.2s forwards; }
.frag-3 { animation: fragmentFly3 0.8s ease-out 0.2s forwards; }
.frag-4 { animation: fragmentFly4 0.8s ease-out 0.2s forwards; }
.frag-5 { animation: fragmentFly5 0.8s ease-out 0.2s forwards; }
.frag-6 { animation: fragmentFly6 0.8s ease-out 0.2s forwards; }
.frag-7 { animation: fragmentFly7 0.8s ease-out 0.2s forwards; }
.frag-8 { animation: fragmentFly8 0.8s ease-out 0.2s forwards; }

@keyframes duckFadeIn {
  0% { opacity: 0; transform: scale(0.8); }
  100% { opacity: 1; transform: scale(1); }
}

@keyframes shatterOut {
  0% { transform: scale(1); opacity: 1; }
  50% { transform: scale(1.2); opacity: 0.6; }
  100% { transform: scale(0); opacity: 0; }
}

@keyframes fragmentFly1 {
  0% { transform: translate(0, 0) rotate(0deg); opacity: 1; }
  100% { transform: translate(-80rpx, -120rpx) rotate(180deg); opacity: 0; }
}

@keyframes fragmentFly2 {
  0% { transform: translate(0, 0) rotate(0deg); opacity: 1; }
  100% { transform: translate(80rpx, -100rpx) rotate(-150deg); opacity: 0; }
}

@keyframes fragmentFly3 {
  0% { transform: translate(0, 0) rotate(0deg); opacity: 1; }
  100% { transform: translate(-120rpx, 40rpx) rotate(210deg); opacity: 0; }
}

@keyframes fragmentFly4 {
  0% { transform: translate(0, 0) rotate(0deg); opacity: 1; }
  100% { transform: translate(100rpx, 60rpx) rotate(-120deg); opacity: 0; }
}

@keyframes fragmentFly5 {
  0% { transform: translate(0, 0) rotate(0deg); opacity: 1; }
  100% { transform: translate(-60rpx, 120rpx) rotate(270deg); opacity: 0; }
}

@keyframes fragmentFly6 {
  0% { transform: translate(0, 0) rotate(0deg); opacity: 1; }
  100% { transform: translate(60rpx, 100rpx) rotate(-240deg); opacity: 0; }
}

@keyframes fragmentFly7 {
  0% { transform: translate(0, 0) rotate(0deg); opacity: 1; }
  100% { transform: translate(-100rpx, -60rpx) rotate(300deg); opacity: 0; }
}

@keyframes fragmentFly8 {
  0% { transform: translate(0, 0) rotate(0deg); opacity: 1; }
  100% { transform: translate(120rpx, -40rpx) rotate(-330deg); opacity: 0; }
}

/* ==============================
   Golden Hatch Animations (~2.7s)
   ============================== */

@keyframes overlayDarken {
  0% { background: rgba(0, 0, 0, 0); }
  100% { background: rgba(0, 0, 0, 0.6); }
}

.spotlight {
  position: absolute;
  width: 200rpx;
  height: 600rpx;
  background: radial-gradient(ellipse at center, rgba(255, 255, 255, 0.3) 0%, rgba(255, 255, 255, 0.05) 50%, transparent 70%);
  animation: spotlightPulse 1s ease-in-out infinite;
  pointer-events: none;
}

@keyframes spotlightPulse {
  0% { opacity: 0.6; transform: scaleX(1); }
  50% { opacity: 1; transform: scaleX(1.2); }
  100% { opacity: 0.6; transform: scaleX(1); }
}

.golden-egg-drop {
  position: relative;
  opacity: 0;
  animation: goldenEggDrop 0.5s ease 0.3s both;
}

@keyframes goldenEggDrop {
  0% {
    opacity: 0;
    transform: translateY(-300rpx) scale(0.5);
  }
  60% {
    opacity: 1;
    transform: translateY(20rpx) scale(1.1);
  }
  80% {
    transform: translateY(-10rpx) scale(0.95);
  }
  100% {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
}

.sparkle {
  position: absolute;
  font-size: 32rpx;
  color: #FFD700;
  animation: sparkleRotate 1s linear infinite;
  pointer-events: none;
}

.sp-1 {
  top: -30rpx;
  left: -40rpx;
  animation-delay: 0s;
}

.sp-2 {
  top: -20rpx;
  right: -40rpx;
  animation-delay: 0.33s;
}

.sp-3 {
  bottom: -30rpx;
  left: 10rpx;
  animation-delay: 0.66s;
}

@keyframes sparkleRotate {
  0% { transform: rotate(0deg) scale(1); opacity: 1; }
  50% { transform: rotate(180deg) scale(1.4); opacity: 0.6; }
  100% { transform: rotate(360deg) scale(1); opacity: 1; }
}

.golden-duck-appear {
  opacity: 0;
  animation: goldenDuckReveal 0.8s ease 1.4s forwards;
  position: relative;
}

@keyframes goldenDuckReveal {
  0% {
    opacity: 0;
    transform: scale(0);
    filter: brightness(2);
  }
  40% {
    opacity: 1;
    transform: scale(1.3);
    filter: brightness(1.5);
  }
  70% {
    transform: scale(0.9);
    filter: brightness(1.2);
  }
  100% {
    opacity: 1;
    transform: scale(1);
    filter: brightness(1) drop-shadow(0 0 16rpx rgba(255, 215, 0, 0.6));
  }
}

.golden-particles {
  position: absolute;
  top: 50%;
  left: 50%;
  width: 0;
  height: 0;
  pointer-events: none;
}

.g-particle {
  position: absolute;
  width: 12rpx;
  height: 12rpx;
  background: #FFD700;
  opacity: 0;
}

.g-particle:nth-child(1) { animation: particleFly0 1s ease-out 1.4s forwards; }
.g-particle:nth-child(2) { animation: particleFly1 1s ease-out 1.45s forwards; }
.g-particle:nth-child(3) { animation: particleFly2 1s ease-out 1.5s forwards; }
.g-particle:nth-child(4) { animation: particleFly3 1s ease-out 1.55s forwards; }
.g-particle:nth-child(5) { animation: particleFly4 1s ease-out 1.4s forwards; }
.g-particle:nth-child(6) { animation: particleFly5 1s ease-out 1.45s forwards; }
.g-particle:nth-child(7) { animation: particleFly6 1s ease-out 1.5s forwards; }
.g-particle:nth-child(8) { animation: particleFly7 1s ease-out 1.55s forwards; }
.g-particle:nth-child(9) { animation: particleFly8 1s ease-out 1.4s forwards; }
.g-particle:nth-child(10) { animation: particleFly9 1s ease-out 1.45s forwards; }
.g-particle:nth-child(11) { animation: particleFly10 1s ease-out 1.5s forwards; }
.g-particle:nth-child(12) { animation: particleFly11 1s ease-out 1.55s forwards; }

@keyframes particleFly0 {
  0% { opacity: 1; transform: translate(0, 0) scale(1); }
  100% { opacity: 0; transform: translate(-140rpx, -200rpx) scale(0.3); }
}
@keyframes particleFly1 {
  0% { opacity: 1; transform: translate(0, 0) scale(1); }
  100% { opacity: 0; transform: translate(-60rpx, -220rpx) scale(0.3); }
}
@keyframes particleFly2 {
  0% { opacity: 1; transform: translate(0, 0) scale(1); }
  100% { opacity: 0; transform: translate(60rpx, -200rpx) scale(0.3); }
}
@keyframes particleFly3 {
  0% { opacity: 1; transform: translate(0, 0) scale(1); }
  100% { opacity: 0; transform: translate(150rpx, -180rpx) scale(0.3); }
}
@keyframes particleFly4 {
  0% { opacity: 1; transform: translate(0, 0) scale(1); }
  100% { opacity: 0; transform: translate(200rpx, -40rpx) scale(0.3); }
}
@keyframes particleFly5 {
  0% { opacity: 1; transform: translate(0, 0) scale(1); }
  100% { opacity: 0; transform: translate(180rpx, 100rpx) scale(0.3); }
}
@keyframes particleFly6 {
  0% { opacity: 1; transform: translate(0, 0) scale(1); }
  100% { opacity: 0; transform: translate(80rpx, 190rpx) scale(0.3); }
}
@keyframes particleFly7 {
  0% { opacity: 1; transform: translate(0, 0) scale(1); }
  100% { opacity: 0; transform: translate(-30rpx, 210rpx) scale(0.3); }
}
@keyframes particleFly8 {
  0% { opacity: 1; transform: translate(0, 0) scale(1); }
  100% { opacity: 0; transform: translate(-130rpx, 150rpx) scale(0.3); }
}
@keyframes particleFly9 {
  0% { opacity: 1; transform: translate(0, 0) scale(1); }
  100% { opacity: 0; transform: translate(-200rpx, 30rpx) scale(0.3); }
}
@keyframes particleFly10 {
  0% { opacity: 1; transform: translate(0, 0) scale(1); }
  100% { opacity: 0; transform: translate(-190rpx, -80rpx) scale(0.3); }
}
@keyframes particleFly11 {
  0% { opacity: 1; transform: translate(0, 0) scale(1); }
  100% { opacity: 0; transform: translate(20rpx, -240rpx) scale(0.3); }
}

.achievement-text {
  margin-top: 40rpx;
  font-size: 36rpx;
  font-weight: bold;
  color: #FFD700;
  text-shadow: 0 0 10rpx rgba(255, 215, 0, 0.8), 0 0 20rpx rgba(255, 215, 0, 0.4);
  font-family: monospace;
  letter-spacing: 4rpx;
  animation: textPopIn 0.5s ease both;
}

@keyframes textPopIn {
  0% {
    opacity: 0;
    transform: scale(0);
  }
  60% {
    opacity: 1;
    transform: scale(1.2);
  }
  100% {
    opacity: 1;
    transform: scale(1);
  }
}

/* ==============================
   Golden Death Animations (~1.9s)
   ============================== */

.red-flash {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  border: 8rpx solid rgba(255, 0, 0, 0.6);
  box-shadow: inset 0 0 60rpx rgba(255, 0, 0, 0.3);
  animation: redFlashPulse 0.2s ease 2;
  pointer-events: none;
}

@keyframes redFlashPulse {
  0% { opacity: 0; }
  50% { opacity: 1; }
  100% { opacity: 0; }
}

.golden-death-scene {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
}

.crown-fall {
  animation: crownDrop 0.4s ease 0.5s forwards;
}

@keyframes crownDrop {
  0% {
    transform: translateY(0) rotate(0deg);
    opacity: 1;
  }
  100% {
    transform: translateY(160rpx) rotate(45deg);
    opacity: 0;
  }
}

.golden-shatter {
  animation: shatterOut 0.6s ease 0.9s forwards;
}

.golden-frag {
  background: #FFD700;
  filter: drop-shadow(0 0 4rpx gold);
}

.golden-shatter .frag-1 { animation: goldenFragFly1 1s ease-out 0.9s forwards; background: #FFD700; filter: drop-shadow(0 0 4rpx gold); }
