/* ==============================
   Overlay & Container
   ============================== */

.duck-anim-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 999;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(0, 0, 0, 0.15);
}

.duck-anim-overlay.golden_hatch {
  background: rgba(0, 0, 0, 0.6);
  animation: overlayDarken 0.5s ease;
}

.duck-anim-overlay.golden_death {
  background: rgba(0, 0, 0, 0.4);
}

.anim-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
}

/* ==============================
   Cartoon Duck
   ============================== */

.cartoon-duck {
  position: relative;
  width: 160rpx;
  height: 200rpx;
}

.duck-body {
  position: absolute;
  bottom: 24rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 140rpx;
  height: 120rpx;
  background: #FFD600;
  border-radius: 50%;
}

.duck-head {
  position: absolute;
  top: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 100rpx;
  height: 90rpx;
  background: #FFD600;
  border-radius: 50%;
  z-index: 2;
}

.duck-eye {
  position: absolute;
  top: 28rpx;
  right: 22rpx;
  width: 20rpx;
  height: 22rpx;
  background: #333;
  border-radius: 50%;
}

.eye-highlight {
  position: absolute;
  top: 4rpx;
  right: 4rpx;
  width: 8rpx;
  height: 8rpx;
  background: #fff;
  border-radius: 50%;
}

.duck-beak {
  position: absolute;
  top: 40rpx;
  right: -16rpx;
  width: 28rpx;
  height: 16rpx;
  background: #FF8F00;
  border-radius: 0 60% 60% 0;
}

.duck-blush {
  position: absolute;
  bottom: 16rpx;
  right: 14rpx;
  width: 20rpx;
  height: 14rpx;
  background: rgba(255, 171, 145, 0.5);
  border-radius: 50%;
}

.duck-wing {
  position: absolute;
  top: 90rpx;
  left: -4rpx;
  width: 50rpx;
  height: 40rpx;
  background: #FFC107;
  border-radius: 50%;
  transform: rotate(-20deg);
  z-index: 1;
}

.duck-feet {
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  gap: 20rpx;
}

.duck-foot {
  width: 24rpx;
  height: 10rpx;
  background: #FF8F00;
  border-radius: 50%;
}

/* Dead eye — ✕ text replaces circle */
.dead-eye {
  background: none !important;
  font-size: 20rpx;
  color: #333;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: bold;
  line-height: 1;
}

.dead-eye .eye-highlight {
  display: none;
}

/* ==============================
   Golden Duck Overrides
   ============================== */

.cartoon-duck.golden .duck-body {
  background: #FFD700;
}

.cartoon-duck.golden .duck-head {
  background: #FFD700;
}

.cartoon-duck.golden .duck-wing {
  background: #FFA000;
}

.cartoon-duck.golden {
  filter: drop-shadow(0 0 16rpx rgba(255, 215, 0, 0.5));
}

.cartoon-duck.golden .duck-eye {
  background: #5D4037;
}

.cartoon-duck.golden .duck-beak {
  background: #FFA000;
}

.cartoon-duck.golden .duck-foot {
  background: #FFA000;
}

/* ==============================
   Crown (CSS triangles)
   ============================== */

.duck-crown {
  position: absolute;
  top: -28rpx;
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  align-items: flex-end;
  justify-content: center;
  gap: 0;
  z-index: 3;
}

.crown-point {
  width: 0;
  height: 0;
  border-left: 8rpx solid transparent;
  border-right: 8rpx solid transparent;
  border-bottom: 14rpx solid #FFD700;
  margin: 0 1rpx;
}

.crown-base {
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 52rpx;
  height: 8rpx;
  background: #FFD700;
  border-radius: 0 0 4rpx 4rpx;
}

/* ==============================
   Cartoon Egg
   ============================== */

.cartoon-egg {
  width: 100rpx;
  height: 130rpx;
  background: #FFF8E1;
  border-radius: 45% 45% 50% 50%;
  border: 3rpx solid #E0D5C0;
  position: relative;
  overflow: hidden;
}

.cartoon-egg.golden {
  background: linear-gradient(135deg, #FFE44D 0%, #FFD700 40%, #FFC107 70%, #FFA000 100%);
  border-color: #FFA000;
  box-shadow: 0 0 20rpx rgba(255, 215, 0, 0.5);
}

.egg-crack {
  position: absolute;
  top: 50%;
  left: 0;
  width: 100%;
  height: 0;
  opacity: 0;
}

.egg-crack::after {
  content: '';
  position: absolute;
  top: -2rpx;
  left: 10%;
  width: 80%;
  height: 4rpx;
  background:
    linear-gradient(135deg, transparent 20%, #8D6E63 20%, #8D6E63 25%, transparent 25%) 0 0 / 14rpx 4rpx repeat-x;
}

/* ==============================
   Normal Hatch Animations (~1s)
   ============================== */

.egg-wrap {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
}

.normal-egg-anim {
  animation: eggBounceIn 0.3s ease-out, eggCrack 0.4s ease 0.3s forwards;
}

.normal-egg-anim .egg-crack {
  animation: crackReveal 0.4s ease 0.3s forwards;
}

.duck-appear {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
}

.normal-duck-appear {
  opacity: 0;
  animation: duckPopOut 0.3s ease 0.7s forwards;
}

@keyframes eggBounceIn {
  0% {
    transform: scale(0) translateY(-60rpx);
    opacity: 0;
  }
  60% {
    transform: scale(1.1) translateY(10rpx);
    opacity: 1;
  }
  80% {
    transform: scale(0.95) translateY(-5rpx);
  }
  100% {
    transform: scale(1) translateY(0);
    opacity: 1;
  }
}

@keyframes crackReveal {
  0% { opacity: 0; }
  40% { opacity: 1; }
  100% { opacity: 1; }
}

@keyframes eggCrack {
  0% {
    transform: scale(1) rotate(0deg);
    opacity: 1;
  }
  20% {
    transform: scale(1.05) rotate(-3deg);
  }
  40% {
    transform: scale(1.05) rotate(3deg);
  }
  60% {
    transform: scale(1.1) rotate(-2deg);
  }
  80% {
    transform: scale(0.5) rotate(5deg);
    opacity: 0.5;
  }
  100% {
    transform: scale(0) rotate(10deg);
    opacity: 0;
  }
}

@keyframes duckPopOut {
  0% {
    opacity: 0;
    transform: translate(-50%, -50%) scale(0.5);
  }
  60% {
    opacity: 1;
    transform: translate(-50%, -50%) scale(1.1);
  }
  80% {
    transform: translate(-50%, -50%) scale(0.95) translateY(-10rpx);
  }
  100% {
    opacity: 1;
    transform: translate(-50%, -50%) scale(1) translateY(0);
  }
}

/* ==============================
   Normal Death Animations (~1s)
   ============================== */

.duck-shatter {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
}

.normal-shatter {
  animation: duckFadeIn 0.2s ease;
}

.death-duck {
  animation: shatterOut 0.5s ease 0.2s forwards;
}

.break-particle {
  position: absolute;
  font-size: 36rpx;
  opacity: 1;
}

.bp-1 { animation: bpFly1 0.8s ease-out 0.2s forwards; }
.bp-2 { animation: bpFly2 0.8s ease-out 0.25s forwards; }
.bp-3 { animation: bpFly3 0.8s ease-out 0.2s forwards; }
.bp-4 { animation: bpFly4 0.8s ease-out 0.25s forwards; }
.bp-5 { animation: bpFly5 0.8s ease-out 0.2s forwards; }
.bp-6 { animation: bpFly6 0.8s ease-out 0.25s forwards; }

.golden-bp {
  font-size: 42rpx;
  filter: drop-shadow(0 0 6rpx rgba(255, 215, 0, 0.6));
}

@keyframes duckFadeIn {
  0% { opacity: 0; transform: scale(0.8); }
  100% { opacity: 1; transform: scale(1); }
}

@keyframes shatterOut {
  0% { transform: scale(1); opacity: 1; }
  50% { transform: scale(1.2); opacity: 0.6; }
  100% { transform: scale(0); opacity: 0; }
}

@keyframes bpFly1 {
  0% { transform: translate(0, 0) scale(1); opacity: 1; }
  100% { transform: translate(-100rpx, -140rpx) scale(0.4); opacity: 0; }
}

@keyframes bpFly2 {
  0% { transform: translate(0, 0) scale(1); opacity: 1; }
  100% { transform: translate(90rpx, -120rpx) scale(0.4); opacity: 0; }
}

@keyframes bpFly3 {
  0% { transform: translate(0, 0) scale(1); opacity: 1; }
  100% { transform: translate(-130rpx, 50rpx) scale(0.4); opacity: 0; }
}

@keyframes bpFly4 {
  0% { transform: translate(0, 0) scale(1); opacity: 1; }
  100% { transform: translate(110rpx, 70rpx) scale(0.4); opacity: 0; }
}

@keyframes bpFly5 {
  0% { transform: translate(0, 0) scale(1); opacity: 1; }
  100% { transform: translate(-70rpx, 130rpx) scale(0.4); opacity: 0; }
}

@keyframes bpFly6 {
  0% { transform: translate(0, 0) scale(1); opacity: 1; }
  100% { transform: translate(70rpx, 110rpx) scale(0.4); opacity: 0; }
}

/* ==============================
   Golden Hatch Animations (~2.7s)
   ============================== */

@keyframes overlayDarken {
  0% { background: rgba(0, 0, 0, 0); }
  100% { background: rgba(0, 0, 0, 0.6); }
}

.spotlight {
  position: absolute;
  width: 200rpx;
  height: 600rpx;
  background: radial-gradient(ellipse at center, rgba(255, 255, 255, 0.3) 0%, rgba(255, 255, 255, 0.05) 50%, transparent 70%);
  animation: spotlightPulse 1s ease-in-out infinite;
  pointer-events: none;
}

@keyframes spotlightPulse {
  0% { opacity: 0.6; transform: scaleX(1); }
  50% { opacity: 1; transform: scaleX(1.2); }
  100% { opacity: 0.6; transform: scaleX(1); }
}

.golden-egg-drop {
  position: relative;
  opacity: 0;
  animation: goldenEggDrop 0.5s ease 0.3s both;
}

.golden-egg-drop .egg-crack {
  animation: crackReveal 0.6s ease 0.6s forwards;
}

@keyframes goldenEggDrop {
  0% {
    opacity: 0;
    transform: translateY(-300rpx) scale(0.5);
  }
  60% {
    opacity: 1;
    transform: translateY(20rpx) scale(1.1);
  }
  80% {
    transform: translateY(-10rpx) scale(0.95);
  }
  100% {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
}

.sparkle {
  position: absolute;
  font-size: 32rpx;
  color: #FFD700;
  animation: sparkleRotate 1s linear infinite;
  pointer-events: none;
}

.sp-1 {
  top: -30rpx;
  left: -40rpx;
  animation-delay: 0s;
}

.sp-2 {
  top: -20rpx;
  right: -40rpx;
  animation-delay: 0.33s;
}

.sp-3 {
  bottom: -30rpx;
  left: 10rpx;
  animation-delay: 0.66s;
}

@keyframes sparkleRotate {
  0% { transform: rotate(0deg) scale(1); opacity: 1; }
  50% { transform: rotate(180deg) scale(1.4); opacity: 0.6; }
  100% { transform: rotate(360deg) scale(1); opacity: 1; }
}

.golden-duck-appear {
  opacity: 0;
  animation: goldenDuckReveal 0.8s ease 1.4s forwards;
  position: relative;
}

@keyframes goldenDuckReveal {
  0% {
    opacity: 0;
    transform: scale(0);
    filter: brightness(2);
  }
  40% {
    opacity: 1;
    transform: scale(1.3);
    filter: brightness(1.5);
  }
  70% {
    transform: scale(0.9);
    filter: brightness(1.2);
  }
  100% {
    opacity: 1;
    transform: scale(1);
    filter: brightness(1) drop-shadow(0 0 16rpx rgba(255, 215, 0, 0.6));
  }
}

.golden-particles {
  position: absolute;
  top: 50%;
  left: 50%;
  width: 0;
  height: 0;
  pointer-events: none;
}

.g-particle {
  position: absolute;
  font-size: 28rpx;
  color: #FFD700;
  opacity: 0;
  text-shadow: 0 0 8rpx rgba(255, 215, 0, 0.8);
}

.g-particle:nth-child(1) { animation: particleFly0 1s ease-out 1.4s forwards; }
.g-particle:nth-child(2) { animation: particleFly1 1s ease-out 1.45s forwards; }
.g-particle:nth-child(3) { animation: particleFly2 1s ease-out 1.5s forwards; }
.g-particle:nth-child(4) { animation: particleFly3 1s ease-out 1.55s forwards; }
.g-particle:nth-child(5) { animation: particleFly4 1s ease-out 1.4s forwards; }
.g-particle:nth-child(6) { animation: particleFly5 1s ease-out 1.45s forwards; }
.g-particle:nth-child(7) { animation: particleFly6 1s ease-out 1.5s forwards; }
.g-particle:nth-child(8) { animation: particleFly7 1s ease-out 1.55s forwards; }
.g-particle:nth-child(9) { animation: particleFly8 1s ease-out 1.4s forwards; }
.g-particle:nth-child(10) { animation: particleFly9 1s ease-out 1.45s forwards; }
.g-particle:nth-child(11) { animation: particleFly10 1s ease-out 1.5s forwards; }
.g-particle:nth-child(12) { animation: particleFly11 1s ease-out 1.55s forwards; }

@keyframes particleFly0 {
  0% { opacity: 1; transform: translate(0, 0) scale(1); }
  100% { opacity: 0; transform: translate(-140rpx, -200rpx) scale(0.3); }
}

@keyframes particleFly1 {
  0% { opacity: 1; transform: translate(0, 0) scale(1); }
  100% { opacity: 0; transform: translate(-60rpx, -220rpx) scale(0.3); }
}

@keyframes particleFly2 {
  0% { opacity: 1; transform: translate(0, 0) scale(1); }
  100% { opacity: 0; transform: translate(60rpx, -200rpx) scale(0.3); }
}

@keyframes particleFly3 {
  0% { opacity: 1; transform: translate(0, 0) scale(1); }
  100% { opacity: 0; transform: translate(150rpx, -180rpx) scale(0.3); }
}

@keyframes particleFly4 {
  0% { opacity: 1; transform: translate(0, 0) scale(1); }
  100% { opacity: 0; transform: translate(200rpx, -40rpx) scale(0.3); }
}

@keyframes particleFly5 {
  0% { opacity: 1; transform: translate(0, 0) scale(1); }
  100% { opacity: 0; transform: translate(180rpx, 100rpx) scale(0.3); }
}

@keyframes particleFly6 {
  0% { opacity: 1; transform: translate(0, 0) scale(1); }
  100% { opacity: 0; transform: translate(80rpx, 190rpx) scale(0.3); }
}

@keyframes particleFly7 {
  0% { opacity: 1; transform: translate(0, 0) scale(1); }
  100% { opacity: 0; transform: translate(-30rpx, 210rpx) scale(0.3); }
}

@keyframes particleFly8 {
  0% { opacity: 1; transform: translate(0, 0) scale(1); }
  100% { opacity: 0; transform: translate(-130rpx, 150rpx) scale(0.3); }
}

@keyframes particleFly9 {
  0% { opacity: 1; transform: translate(0, 0) scale(1); }
  100% { opacity: 0; transform: translate(-200rpx, 30rpx) scale(0.3); }
}

@keyframes particleFly10 {
  0% { opacity: 1; transform: translate(0, 0) scale(1); }
  100% { opacity: 0; transform: translate(-190rpx, -80rpx) scale(0.3); }
}

@keyframes particleFly11 {
  0% { opacity: 1; transform: translate(0, 0) scale(1); }
  100% { opacity: 0; transform: translate(20rpx, -240rpx) scale(0.3); }
}

.achievement-text {
  margin-top: 40rpx;
  font-size: 36rpx;
  font-weight: bold;
  color: #FFD700;
  text-shadow: 0 0 10rpx rgba(255, 215, 0, 0.8), 0 0 20rpx rgba(255, 215, 0, 0.4);
  letter-spacing: 4rpx;
  animation: textPopIn 0.5s ease both;
}

@keyframes textPopIn {
  0% {
    opacity: 0;
    transform: scale(0);
  }
  60% {
    opacity: 1;
    transform: scale(1.2);
  }
  100% {
    opacity: 1;
    transform: scale(1);
  }
}

/* ==============================
   Golden Death Animations (~1.9s)
   ============================== */

.red-flash {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  border: 8rpx solid rgba(255, 0, 0, 0.6);
  box-shadow: inset 0 0 60rpx rgba(255, 0, 0, 0.3);
  animation: redFlashPulse 0.2s ease 2;
  pointer-events: none;
}

@keyframes redFlashPulse {
  0% { opacity: 0; }
  50% { opacity: 1; }
  100% { opacity: 0; }
}

.golden-death-scene {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
}

.crown-fall {
  animation: crownDrop 0.4s ease 0.5s forwards;
}

.golden-death-scene > .duck-crown {
  position: absolute;
  top: -40rpx;
}

@keyframes crownDrop {
  0% {
    transform: translateY(0) rotate(0deg);
    opacity: 1;
  }
  100% {
    transform: translateY(160rpx) rotate(45deg);
    opacity: 0;
  }
}

.golden-shatter {
  animation: shatterOut 0.6s ease 0.9s forwards;
}

.golden-death-scene .bp-1 { animation: goldenBpFly1 1s ease-out 0.9s forwards; }
.golden-death-scene .bp-2 { animation: goldenBpFly2 1s ease-out 0.95s forwards; }
.golden-death-scene .bp-3 { animation: goldenBpFly3 1s ease-out 0.9s forwards; }
.golden-death-scene .bp-4 { animation: goldenBpFly4 1s ease-out 0.95s forwards; }
.golden-death-scene .bp-5 { animation: goldenBpFly5 1s ease-out 0.9s forwards; }
.golden-death-scene .bp-6 { animation: goldenBpFly6 1s ease-out 0.95s forwards; }

@keyframes goldenBpFly1 {
  0% { transform: translate(0, 0) scale(1); opacity: 1; }
  100% { transform: translate(-160rpx, -200rpx) scale(0.3); opacity: 0; }
}

@keyframes goldenBpFly2 {
  0% { transform: translate(0, 0) scale(1); opacity: 1; }
  100% { transform: translate(140rpx, -180rpx) scale(0.3); opacity: 0; }
}

@keyframes goldenBpFly3 {
  0% { transform: translate(0, 0) scale(1); opacity: 1; }
  100% { transform: translate(-200rpx, 60rpx) scale(0.3); opacity: 0; }
}

@keyframes goldenBpFly4 {
  0% { transform: translate(0, 0) scale(1); opacity: 1; }
  100% { transform: translate(180rpx, 80rpx) scale(0.3); opacity: 0; }
}

@keyframes goldenBpFly5 {
  0% { transform: translate(0, 0) scale(1); opacity: 1; }
  100% { transform: translate(-100rpx, 200rpx) scale(0.3); opacity: 0; }
}

@keyframes goldenBpFly6 {
  0% { transform: translate(0, 0) scale(1); opacity: 1; }
  100% { transform: translate(100rpx, 180rpx) scale(0.3); opacity: 0; }
}
