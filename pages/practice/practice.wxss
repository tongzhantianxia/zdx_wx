/* pages/practice/practice.wxss */
.practice-page {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
}

/* 进度条区域 */
.progress-section {
  margin-bottom: var(--spacing-md);
}

.progress-info {
  margin-bottom: var(--spacing-sm);
}

.progress-text {
  font-size: 28rpx;
  color: var(--text-secondary);
}

.progress-score {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--primary-color);
}

.progress-bar {
  border-radius: var(--radius-round);
  overflow: hidden;
}

/* 题目区域 */
.question-section {
  flex: 1;
  margin-bottom: var(--spacing-md);
}

.question-header {
  margin-bottom: var(--spacing-lg);
}

.question-type {
  font-size: 24rpx;
  color: var(--primary-color);
  background-color: rgba(74, 144, 226, 0.1);
  padding: 8rpx 24rpx;
  border-radius: var(--radius-round);
}

.question-difficulty {
  font-size: 24rpx;
  color: var(--warning-color);
}

.question-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 300rpx;
}

.question-text {
  font-size: 48rpx;
  font-weight: 600;
  color: var(--text-primary);
  text-align: center;
}

.question-hint {
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-top: var(--spacing-lg);
  padding: var(--spacing-md);
  background-color: var(--bg-primary);
  border-radius: var(--radius-md);
}

/* 答题区域 */
.answer-section {
  margin-bottom: var(--spacing-lg);
}

.answer-input-wrap {
  background-color: var(--bg-secondary);
  border-radius: var(--radius-lg);
  padding: var(--spacing-lg);
  margin-bottom: var(--spacing-md);
}

.answer-input {
  width: 100%;
  height: 100rpx;
  font-size: 48rpx;
  font-weight: 600;
  text-align: center;
  color: var(--text-primary);
}

.action-buttons {
  display: flex;
  gap: var(--spacing-md);
}

.hint-btn {
  flex: 1;
}

.submit-btn {
  flex: 2;
}

/* 答案反馈 */
.feedback-section {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  border-radius: var(--radius-lg) var(--radius-lg) 0 0;
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
  animation: slideUp 0.3s ease;
}

@keyframes slideUp {
  from {
    transform: translateY(100%);
  }
  to {
    transform: translateY(0);
  }
}

.feedback-section.correct {
  background-color: #F6FFED;
  border-top: 4rpx solid var(--success-color);
}

.feedback-section.wrong {
  background-color: #FFF2F0;
  border-top: 4rpx solid var(--error-color);
}

.feedback-content {
  display: flex;
  align-items: flex-start;
  margin-bottom: var(--spacing-lg);
}

.feedback-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: var(--spacing-md);
  font-size: 36rpx;
  font-weight: 700;
  color: #FFFFFF;
}

.correct .feedback-icon {
  background-color: var(--success-color);
}

.wrong .feedback-icon {
  background-color: var(--error-color);
}

.feedback-text {
  flex: 1;
}

.feedback-title {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.correct .feedback-title {
  color: var(--success-color);
}

.wrong .feedback-title {
  color: var(--error-color);
}

.feedback-answer {
  display: block;
  font-size: 28rpx;
  color: var(--text-primary);
  margin-bottom: 8rpx;
}

.feedback-explanation {
  display: block;
  font-size: 26rpx;
  color: var(--text-secondary);
}

.next-btn {
  width: 100%;
}
