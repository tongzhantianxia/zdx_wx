/* pages/practice/practice.wxss */
.practice-page {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  position: relative;
  padding: calc(24rpx + env(safe-area-inset-top)) 24rpx calc(36rpx + env(safe-area-inset-bottom));
  overflow: hidden;
}

.bg-grid {
  position: absolute;
  inset: 0;
  opacity: 0.4;
  background-image:
    linear-gradient(rgba(130, 164, 244, 0.08) 1rpx, transparent 1rpx),
    linear-gradient(90deg, rgba(130, 164, 244, 0.08) 1rpx, transparent 1rpx);
  background-size: 44rpx 44rpx;
  z-index: 0;
  pointer-events: none;
}

.practice-page .card,
.answer-section {
  position: relative;
  z-index: 1;
}

/* 进度条区域 */
.progress-section {
  margin-bottom: var(--spacing-md);
}

.progress-info {
  margin-bottom: var(--spacing-sm);
}

.progress-text {
  font-size: 28rpx;
  color: #bac9ec;
}

.progress-score {
  font-size: 28rpx;
  font-weight: 600;
  color: #80ffe3;
}

.progress-bar {
  border-radius: var(--radius-round);
  overflow: hidden;
}

/* 题目区域 */
.question-section {
  flex: 1;
  margin-bottom: var(--spacing-md);
}

.question-header {
  margin-bottom: var(--spacing-lg);
}

.question-type {
  font-size: 24rpx;
  color: #80ffe3;
  background-color: rgba(88, 216, 255, 0.12);
  padding: 8rpx 24rpx;
  border-radius: var(--radius-round);
}

.question-difficulty {
  font-size: 24rpx;
  color: #ffbf61;
}

.question-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 240rpx;
  padding: 20rpx 0;
}

.question-text {
  font-size: 56rpx;
  font-weight: 700;
  color: #f7fbff;
  text-align: center;
  letter-spacing: 2rpx;
}

.question-hint {
  font-size: 26rpx;
  color: #d3def8;
  margin-top: var(--spacing-lg);
  padding: var(--spacing-md);
  background-color: var(--bg-primary);
  border-radius: var(--radius-md);
}

/* 答题区域 */
.answer-section {
  margin-bottom: var(--spacing-lg);
  display: flex;
  flex-direction: column;
  align-items: center;
}

.answer-label {
  font-size: 26rpx;
  color: #80ffe3;
  margin-bottom: 16rpx;
  letter-spacing: 2rpx;
  text-transform: uppercase;
}

.answer-input-wrap {
  width: 100%;
  background-color: rgba(18, 28, 50, 0.92);
  border: 2rpx solid rgba(118, 155, 240, 0.35);
  border-radius: 32rpx;
  padding: 12rpx 24rpx;
  margin-bottom: 40rpx;
  position: relative;
  display: flex;
  align-items: center;
  box-shadow: inset 0 4rpx 12rpx rgba(0, 0, 0, 0.2);
}

.answer-input {
  flex: 1;
  height: 120rpx;
  font-size: 56rpx;
  font-weight: 700;
  text-align: center;
  color: #58d8ff;
  letter-spacing: 4rpx;
}

.answer-placeholder {
  color: rgba(118, 155, 240, 0.3);
  font-weight: 400;
  font-size: 36rpx;
  letter-spacing: 0;
}

.keyboard-done-btn {
  position: absolute;
  right: 24rpx;
  width: 80rpx;
  height: 80rpx;
  border-radius: 24rpx;
  background: linear-gradient(135deg, #2c83ff 0%, #58d8ff 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #071326;
  font-size: 40rpx;
  font-weight: 800;
  box-shadow: 0 8rpx 16rpx rgba(44, 131, 255, 0.3);
  transition: transform 0.1s;
}

.keyboard-done-btn:active {
  transform: scale(0.92);
}

.action-buttons {
  width: 100%;
  display: flex;
  gap: var(--spacing-md);
}

.hint-btn {
  flex: 1;
}

.submit-btn {
  flex: 2;
}

/* 答案反馈 */
.feedback-section {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  border-radius: 30rpx 30rpx 0 0;
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
  animation: slideUp 0.3s ease;
  box-shadow: 0 -20rpx 56rpx rgba(0, 0, 0, 0.45);
  z-index: 30;
}

@keyframes slideUp {
  from {
    transform: translateY(100%);
  }
  to {
    transform: translateY(0);
  }
}

.feedback-section.correct {
  background-color: #101f1c;
  border-top: 4rpx solid #5cf5a7;
}

.feedback-section.wrong {
  background-color: #241421;
  border-top: 4rpx solid #ff6b8e;
}

.feedback-content {
  display: flex;
  align-items: flex-start;
  margin-bottom: var(--spacing-lg);
}

.feedback-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: var(--spacing-md);
  font-size: 48rpx;
  color: #FFFFFF;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.2);
  overflow: hidden;
}

.feedback-img {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.correct .feedback-icon {
  background-color: rgba(92, 245, 167, 0.2);
  border: 2rpx solid #5cf5a7;
}

.wrong .feedback-icon {
  background-color: rgba(255, 107, 142, 0.2);
  border: 2rpx solid #ff6b8e;
}

.feedback-text {
  flex: 1;
}

.feedback-title {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.correct .feedback-title {
  color: #5cf5a7;
}

.wrong .feedback-title {
  color: #ff6b8e;
}

.feedback-answer {
  display: block;
  font-size: 28rpx;
  color: #eff5ff;
  margin-bottom: 8rpx;
}

.feedback-explanation {
  display: block;
  font-size: 26rpx;
  color: #bfd0f6;
}

.next-btn {
  width: 100%;
}
