/* pages/practice/practice.wxss */

.practice-page {
  min-height: 100vh;
  background-color: var(--bg-page);
  padding: calc(32rpx + env(safe-area-inset-top)) 24rpx calc(48rpx + env(safe-area-inset-bottom));
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

/* ==================== 进度区 ==================== */
.progress-bar-section {
  background-color: #FFFFFF;
  border-radius: var(--radius-lg);
  padding: 28rpx 32rpx;
  box-shadow: var(--shadow-sm);
}

.progress-info {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.progress-left {
  display: flex;
  align-items: baseline;
  gap: 4rpx;
}

.progress-label {
  font-size: 26rpx;
  color: var(--text-sub);
}

.progress-num {
  font-size: 44rpx;
  font-weight: 800;
  color: var(--yellow);
  line-height: 1;
}

.score-badge {
  display: flex;
  align-items: center;
  gap: 6rpx;
  background-color: var(--yellow-bg);
  border-radius: var(--radius-round);
  padding: 8rpx 20rpx;
}

.score-icon {
  font-size: 28rpx;
  line-height: 1;
}

.score-val {
  font-size: 32rpx;
  font-weight: 800;
  color: var(--yellow-deep);
}

.score-label {
  font-size: 24rpx;
  color: var(--text-sub);
}

/* 进度条 */
.progress-track {
  height: 16rpx;
  background-color: var(--border-light);
  border-radius: var(--radius-round);
  position: relative;
  overflow: visible;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, var(--yellow-light), var(--yellow));
  border-radius: var(--radius-round);
  transition: width 0.4s ease;
  box-shadow: 0 2rpx 8rpx rgba(255, 184, 0, 0.4);
}

.progress-duck {
  position: absolute;
  top: -12rpx;
  transition: left 0.4s ease;
}

/* ==================== 题目卡片 ==================== */
.question-card {
  background-color: #FFFFFF;
  border-radius: var(--radius-xl);
  padding: 36rpx 32rpx;
  box-shadow: var(--shadow-md);
  flex: 1;
  min-height: 280rpx;
}

.question-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 32rpx;
}

.type-tag {
  font-size: 22rpx;
  color: var(--blue);
  background-color: var(--blue-bg);
  padding: 6rpx 20rpx;
  border-radius: var(--radius-round);
  font-weight: 500;
}

.diff-tag {
  font-size: 22rpx;
  padding: 6rpx 20rpx;
  border-radius: var(--radius-round);
  font-weight: 500;
}

.diff-1 {
  background-color: var(--success-light);
  color: var(--success);
}

.diff-2 {
  background-color: var(--warning-bg);
  color: var(--warning);
}

.diff-3 {
  background-color: var(--error-bg);
  color: var(--error);
}

.question-body {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 180rpx;
  padding: 16rpx 0;
}

.question-text {
  font-size: 60rpx;
  font-weight: 800;
  color: var(--text-main);
  text-align: center;
  line-height: 1.4;
  letter-spacing: 2rpx;
}

.hint-box {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  margin-top: 24rpx;
  background-color: var(--yellow-bg);
  border-radius: var(--radius-md);
  padding: 20rpx 24rpx;
}

.hint-icon {
  font-size: 28rpx;
  line-height: 1.6;
  flex-shrink: 0;
}

.hint-text {
  font-size: 26rpx;
  color: var(--text-body);
  line-height: 1.6;
}

/* ==================== 答题区 ==================== */
.answer-section {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.answer-label {
  font-size: 26rpx;
  color: var(--text-sub);
  margin-bottom: 16rpx;
  align-self: flex-start;
}

.answer-input-wrap {
  width: 100%;
  background-color: #FFFFFF;
  border: 3rpx solid var(--border);
  border-radius: var(--radius-xl);
  padding: 4rpx 20rpx;
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
  box-shadow: var(--shadow-sm);
  transition: border-color var(--ease);
}

.answer-input-wrap:focus-within {
  border-color: var(--yellow);
  box-shadow: 0 0 0 4rpx rgba(255, 184, 0, 0.15);
}

.answer-input {
  flex: 1;
  height: 110rpx;
  font-size: 60rpx;
  font-weight: 800;
  text-align: center;
  color: var(--yellow-deep);
  letter-spacing: 4rpx;
}

.answer-placeholder {
  color: var(--border);
  font-weight: 400;
  font-size: 36rpx;
  letter-spacing: 0;
}

.confirm-btn {
  width: 72rpx;
  height: 72rpx;
  border-radius: var(--radius-md);
  background: linear-gradient(135deg, var(--yellow-light), var(--yellow));
  display: flex;
  align-items: center;
  justify-content: center;
  color: #FFFFFF;
  font-size: 36rpx;
  font-weight: 800;
  box-shadow: var(--shadow-yellow);
  flex-shrink: 0;
}

.confirm-btn:active {
  transform: scale(0.92);
}

.action-row {
  width: 100%;
  display: flex;
  gap: 20rpx;
}

.hint-btn {
  flex: 1;
  height: 88rpx;
  border-radius: var(--radius-round);
  background-color: var(--yellow-bg);
  color: var(--yellow-deep);
  font-size: 28rpx;
  font-weight: 600;
  border: 2rpx solid rgba(255, 184, 0, 0.3);
}

.hint-btn::after {
  border: none;
}

.submit-btn {
  flex: 2;
  height: 88rpx;
  border-radius: var(--radius-round);
  background: linear-gradient(135deg, var(--yellow-light), var(--yellow));
  color: #FFFFFF;
  font-size: 30rpx;
  font-weight: 700;
  border: none;
  box-shadow: var(--shadow-yellow);
}

.submit-btn.submit-disabled {
  background: #E8E8E8;
  color: #AAAAAA;
  box-shadow: none;
}

.submit-btn::after {
  border: none;
}

/* ==================== 答案反馈弹层 ==================== */
.feedback-sheet {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  border-radius: 40rpx 40rpx 0 0;
  padding: 16rpx 32rpx calc(32rpx + env(safe-area-inset-bottom));
  animation: slideUp 0.3s ease;
  box-shadow: 0 -8rpx 40rpx rgba(0, 0, 0, 0.12);
  z-index: 30;
}

.feedback-sheet.correct {
  background-color: #F0FFF8;
  border-top: 4rpx solid #52C41A;
}

.feedback-sheet.wrong {
  background-color: #FFF5F5;
  border-top: 4rpx solid #FF4D4F;
}

@keyframes slideUp {
  from { transform: translateY(100%); }
  to { transform: translateY(0); }
}

.feedback-handle {
  width: 80rpx;
  height: 8rpx;
  background-color: var(--border);
  border-radius: var(--radius-round);
  margin: 0 auto 28rpx;
}

.feedback-body {
  display: flex;
  align-items: flex-start;
  gap: 24rpx;
  margin-bottom: 32rpx;
}

.feedback-icon-wrap {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  overflow: hidden;
}

.icon-correct {
  background-color: rgba(82, 196, 26, 0.12);
  border: 3rpx solid rgba(82, 196, 26, 0.4);
}

.icon-wrong {
  background-color: rgba(255, 77, 79, 0.1);
  border: 3rpx solid rgba(255, 77, 79, 0.3);
}

.feedback-duck {
  width: 100%;
  height: 100%;
}

.feedback-emoji {
  font-size: 52rpx;
}

.feedback-info {
  flex: 1;
}

.feedback-title {
  display: block;
  font-size: 34rpx;
  font-weight: 700;
  margin-bottom: 12rpx;
}

.title-correct {
  color: var(--success);
}

.title-wrong {
  color: var(--error);
}

.feedback-answer {
  display: block;
  font-size: 28rpx;
  color: var(--text-body);
  margin-bottom: 8rpx;
  font-weight: 600;
}

.feedback-explain {
  display: block;
  font-size: 26rpx;
  color: var(--text-sub);
  line-height: 1.6;
}

.next-btn {
  width: 100%;
  height: 96rpx;
  border-radius: var(--radius-round);
  background: linear-gradient(135deg, var(--yellow-light), var(--yellow));
  color: #FFFFFF;
  font-size: 32rpx;
  font-weight: 700;
  border: none;
  box-shadow: var(--shadow-yellow);
  letter-spacing: 2rpx;
}

.next-btn::after {
  border: none;
}

.next-btn:active {
  transform: scale(0.97);
}
