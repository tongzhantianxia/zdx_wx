/* pages/privacy/privacy.wxss */

.container {
  min-height: 100vh;
  background-color: #FFFFFF;
  padding-bottom: 140rpx;
}

.header {
  padding: 48rpx 32rpx 32rpx;
  text-align: center;
  background: linear-gradient(135deg, #4A90E2 0%, #6BA3E8 100%);
}

.title {
  display: block;
  font-size: 36rpx;
  font-weight: 600;
  color: #FFFFFF;
  margin-bottom: 12rpx;
}

.update-time {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

.content {
  padding: 32rpx;
}

.section {
  margin-bottom: 40rpx;
}

.section-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 16rpx;
}

.section-text {
  display: block;
  font-size: 28rpx;
  color: #666666;
  line-height: 1.8;
}

.list-item {
  display: flex;
  align-items: flex-start;
  margin-top: 12rpx;
}

.list-dot {
  font-size: 28rpx;
  color: #4A90E2;
  margin-right: 12rpx;
}

.list-text {
  font-size: 28rpx;
  color: #666666;
  line-height: 1.6;
  flex: 1;
}

.contact-info {
  margin-top: 16rpx;
  padding: 20rpx;
  background-color: #F5F7FA;
  border-radius: 12rpx;
}

.contact-text {
  font-size: 28rpx;
  color: #4A90E2;
}

.footer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background-color: #FFFFFF;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.08);
}

.agree-btn {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #4A90E2 0%, #6BA3E8 100%);
  color: #FFFFFF;
  font-size: 32rpx;
  font-weight: 500;
  border-radius: 44rpx;
  border: none;
}

.agree-btn::after {
  border: none;
}
