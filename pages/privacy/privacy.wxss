/* pages/privacy/privacy.wxss */

.container {
  min-height: 100vh;
  background-color: var(--bg-page);
  padding-top: calc(12rpx + env(safe-area-inset-top));
  padding-bottom: calc(200rpx + env(safe-area-inset-bottom));
}

/* ==================== 顶部 header ==================== */
.header {
  background: linear-gradient(135deg, var(--yellow-bg) 0%, var(--blue-bg) 100%);
  border-radius: var(--radius-xl);
  margin: 24rpx 24rpx 0;
  padding: 40rpx 32rpx;
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: var(--shadow-sm);
}

.mascot-mini {
  width: 100rpx;
  height: 100rpx;
  margin-bottom: 20rpx;
  border-radius: 50%;
  border: 4rpx solid var(--yellow);
  box-shadow: 0 4rpx 16rpx rgba(255, 184, 0, 0.3);
}

.title {
  display: block;
  font-size: 34rpx;
  font-weight: 700;
  color: var(--text-main);
  margin-bottom: 10rpx;
}

.update-time {
  font-size: 24rpx;
  color: var(--text-hint);
}

/* ==================== 内容区 ==================== */
.content {
  padding: 20rpx 24rpx 0;
}

.section {
  background-color: #FFFFFF;
  border-radius: var(--radius-lg);
  border: 1rpx solid var(--border-light);
  padding: 28rpx 28rpx;
  margin-bottom: 20rpx;
  box-shadow: var(--shadow-sm);
}

.section-title {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text-main);
  margin-bottom: 20rpx;
  border-left: 8rpx solid var(--yellow);
  padding-left: 16rpx;
  border-radius: 4rpx;
}

.section-text {
  display: block;
  font-size: 26rpx;
  color: var(--text-body);
  line-height: 1.8;
  margin-bottom: 12rpx;
}

.subsection {
  margin-top: 20rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid var(--border-light);
}

.subsection-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--blue-deep);
  margin-bottom: 12rpx;
}

.list-item {
  display: flex;
  align-items: flex-start;
  margin-bottom: 12rpx;
}

.list-dot {
  font-size: 26rpx;
  color: var(--yellow);
  margin-right: 12rpx;
  font-weight: 700;
}

.list-text {
  font-size: 26rpx;
  color: var(--text-body);
  line-height: 1.6;
  flex: 1;
}

.contact-box {
  margin-top: 16rpx;
  padding: 20rpx 24rpx;
  background-color: var(--yellow-bg);
  border-radius: var(--radius-md);
  border: 1rpx solid rgba(255, 184, 0, 0.2);
}

.contact-text {
  font-size: 26rpx;
  color: var(--yellow-deep);
  font-weight: 500;
}

/* ==================== 底部同意按钮 ==================== */
.footer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: #FFFFFF;
  border-top: 1rpx solid var(--border-light);
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.06);
  z-index: 20;
}

.agree-btn {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, var(--yellow-light), var(--yellow));
  color: #FFFFFF;
  font-size: 32rpx;
  font-weight: 700;
  border-radius: var(--radius-round);
  border: none;
  box-shadow: var(--shadow-yellow);
}

.agree-btn::after {
  border: none;
}

.agree-btn:active {
  transform: scale(0.97);
}

.footer-tip {
  display: block;
  text-align: center;
  font-size: 22rpx;
  color: var(--text-hint);
  margin-top: 16rpx;
}
