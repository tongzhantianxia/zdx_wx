/* pages/privacy/privacy.wxss */

.container {
  min-height: 100vh;
  background: linear-gradient(165deg, #0b1120 0%, #0f1831 100%);
  padding-top: calc(12rpx + env(safe-area-inset-top));
  padding-bottom: calc(220rpx + env(safe-area-inset-bottom));
}

.header {
  background: linear-gradient(145deg, rgba(25, 38, 68, 0.92) 0%, rgba(20, 32, 57, 0.95) 100%);
  border: 1rpx solid rgba(118, 155, 240, 0.22);
  margin: 24rpx;
  border-radius: 24rpx;
  padding: 40rpx 32rpx;
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.mascot-mini {
  width: 100rpx;
  height: 100rpx;
  margin-bottom: 20rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(88, 216, 255, 0.4);
  box-shadow: 0 4rpx 12rpx rgba(88, 216, 255, 0.2);
}

.title {
  display: block;
  font-size: 36rpx;
  font-weight: 600;
  color: #f4f8ff;
  margin-bottom: 12rpx;
}

.update-time {
  font-size: 24rpx;
  color: #aebde2;
}

.content {
  padding: 24rpx;
  padding-top: 0;
}

.section {
  background-color: rgba(22, 31, 53, 0.9);
  border-radius: 16rpx;
  border: 1rpx solid rgba(118, 155, 240, 0.22);
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.section-title {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: #80ffe3;
  margin-bottom: 20rpx;
  border-left: 8rpx solid #58d8ff;
  padding-left: 16rpx;
  border-radius: 4rpx;
}

.section-text {
  display: block;
  font-size: 26rpx;
  color: #ccdaf9;
  line-height: 1.8;
  margin-bottom: 12rpx;
}

.subsection {
  margin-top: 20rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid rgba(118, 155, 240, 0.2);
}

.subsection-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #58d8ff;
  margin-bottom: 12rpx;
}

.list-item {
  display: flex;
  align-items: flex-start;
  margin-bottom: 12rpx;
}

.list-dot {
  font-size: 26rpx;
  color: #58d8ff;
  margin-right: 12rpx;
}

.list-text {
  font-size: 26rpx;
  color: #ccdaf9;
  line-height: 1.6;
  flex: 1;
}

.contact-box {
  margin-top: 16rpx;
  padding: 20rpx;
  background-color: rgba(10, 18, 35, 0.88);
  border-radius: 12rpx;
}

.contact-text {
  font-size: 26rpx;
  color: #80ffe3;
}

.footer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: rgba(8, 14, 29, 0.92);
  border-top: 1rpx solid rgba(118, 155, 240, 0.25);
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.08);
  z-index: 20;
}

.agree-btn {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #2c83ff 0%, #58d8ff 70%, #80ffe3 100%);
  color: #071326;
  font-size: 32rpx;
  font-weight: 500;
  border-radius: 44rpx;
  border: none;
}

.agree-btn::after {
  border: none;
}

.footer-tip {
  display: block;
  text-align: center;
  font-size: 22rpx;
  color: #91a4cf;
  margin-top: 16rpx;
}
