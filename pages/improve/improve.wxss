.improve-page {
  min-height: 100vh;
  background: #FFFEF5;
  padding-bottom: calc(320rpx + env(safe-area-inset-bottom));
}

/* ==================== 导航栏 ==================== */
.nav-bar {
  background-color: #FFFFFF;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
  position: sticky;
  top: 0;
  z-index: 100;
}
.nav-content {
  height: 88rpx;
  padding: 0 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.nav-logo {
  display: flex;
  align-items: center;
  gap: 12rpx;
}
.nav-duck {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background-color: #FFF9E6;
  border: 3rpx solid #FFB800;
}
.nav-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #2D2D2D;
  letter-spacing: 2rpx;
}
.capsule-placeholder {
  width: 174rpx;
  height: 64rpx;
  border-radius: 32rpx;
  border: 2rpx solid #EDEDEE;
  opacity: 0;
}

/* ==================== 页面标题 ==================== */
.page-header {
  padding: 30rpx 30rpx 20rpx;
}
.page-title {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: #2D2D2D;
  letter-spacing: 1rpx;
}
.page-desc {
  display: block;
  font-size: 26rpx;
  color: #999;
  margin-top: 8rpx;
}

/* ==================== 上传区 ==================== */
.upload-section {
  margin: 0 30rpx 30rpx;
}
.upload-area {
  border: 4rpx dashed #D0C8B8;
  border-radius: 24rpx;
  padding: 80rpx 0;
  text-align: center;
  background: #FFFCF5;
}
.upload-icon {
  font-size: 80rpx;
  color: #FFB300;
  line-height: 1;
  margin-bottom: 12rpx;
}
.upload-text {
  display: block;
  font-size: 28rpx;
  color: #999;
}

/* ==================== 提示步骤 ==================== */
.tips-section {
  margin: 20rpx 30rpx 0;
}
.tip-card {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx 24rpx;
  margin-bottom: 16rpx;
  border: 3rpx solid #E8E0D0;
}
.tip-icon {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: #FFB300;
  color: #fff;
  font-size: 26rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
}
.tip-text {
  font-size: 28rpx;
  color: #555;
}

/* ==================== 上传进度 ==================== */
.loading-section {
  text-align: center;
  padding: 120rpx 40rpx;
}
.progress-bar-wrap {
  width: 80%;
  height: 12rpx;
  background: #F0ECE0;
  border-radius: 6rpx;
  margin: 0 auto 24rpx;
  overflow: hidden;
}
.progress-bar {
  height: 100%;
  background: #FFB300;
  border-radius: 6rpx;
  transition: width 0.3s;
}
.loading-text {
  display: block;
  font-size: 30rpx;
  color: #555;
  margin-bottom: 8rpx;
}

/* ==================== 扫描识别动画 ==================== */
.scan-section {
  padding: 24rpx 20rpx;
  text-align: center;
}
.scan-wrap {
  position: relative;
  border-radius: 16rpx;
  overflow: hidden;
  background: #fff;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
}
.scan-img {
  width: 100%;
  display: block;
  filter: brightness(0.92);
}
.scan-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  overflow: hidden;
  pointer-events: none;
}
.scan-line {
  position: absolute;
  left: 0;
  right: 0;
  height: 0;
  border-top: 4rpx dashed rgba(220, 30, 20, 0.75);
  animation: scanDown 3s ease-in-out infinite;
}
@keyframes scanDown {
  0% { top: -2%; }
  50% { top: 98%; }
  100% { top: -2%; }
}
.scan-text {
  display: block;
  font-size: 28rpx;
  color: #CC1A10;
  font-weight: 600;
  margin-top: 20rpx;
}

/* ==================== 结果顶部提示 ==================== */
.result-banner {
  padding: 20rpx 30rpx;
  background: #FFF8E1;
  border-bottom: 2rpx solid #FFE082;
}
.banner-text {
  font-size: 26rpx;
  color: #E65100;
  font-weight: 600;
}

/* ==================== Tab 栏 ==================== */
.tab-bar-wrap {
  background: #fff;
  border-bottom: 2rpx solid #E8E0D0;
}
.tab-scroll {
  white-space: nowrap;
}
.tab-inner {
  display: inline-flex;
  padding: 0 20rpx;
}
.tab-item {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 20rpx 24rpx;
  font-size: 26rpx;
  color: #999;
  border-bottom: 4rpx solid transparent;
  flex-shrink: 0;
}
.tab-active {
  color: #333;
  font-weight: 600;
  border-bottom-color: #FFB300;
}
.tab-label {
  font-size: 26rpx;
}
.tab-tag {
  font-size: 20rpx;
  padding: 2rpx 8rpx;
  border-radius: 6rpx;
  font-weight: 500;
}
.tab-tag-wrong {
  background: #FFEBEE;
  color: #C62828;
}
.tab-tag-unanswered {
  background: #FFF3E0;
  color: #E65100;
}

/* ==================== 题目详情 ==================== */
.detail-content {
  padding: 20rpx 30rpx;
}
.detail-card {
  background: #fff;
  border: 3rpx solid #E8E0D0;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
}
.detail-label {
  display: block;
  font-size: 24rpx;
  color: #999;
  font-weight: 600;
  margin-bottom: 12rpx;
}
.detail-img-wrap {
  border-radius: 12rpx;
  overflow: hidden;
  background: #F9F6EE;
}
.detail-img {
  width: 100%;
  display: block;
}
.detail-text {
  display: block;
  font-size: 28rpx;
  color: #333;
  line-height: 1.7;
}
.detail-row {
  display: flex;
  gap: 16rpx;
}
.detail-half {
  flex: 1;
}
.detail-tag {
  display: inline-block;
  font-size: 24rpx;
  padding: 6rpx 16rpx;
  border-radius: 10rpx;
  font-weight: 500;
}
.tag-knowledge {
  color: #FFB300;
  background: #FFF8E1;
}
.tag-diff-easy {
  background: #E8F5E9;
  color: #2E7D32;
}
.tag-diff-medium {
  background: #FFF3E0;
  color: #E65100;
}
.tag-diff-hard {
  background: #FFEBEE;
  color: #C62828;
}

/* ==================== 底部操作栏 ==================== */
.bottom-bar {
  position: fixed;
  bottom: calc(128rpx + env(safe-area-inset-bottom));
  left: 0;
  right: 0;
  background: #fff;
  border-top: 2rpx solid #E8E0D0;
  padding: 20rpx 30rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  z-index: 99;
  box-shadow: 0 -4rpx 12rpx rgba(0, 0, 0, 0.05);
}
.bottom-left {
  display: flex;
  flex-direction: column;
}
.bottom-count {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}
.bottom-actions {
  display: flex;
  align-items: center;
  gap: 20rpx;
}
.btn-retake {
  font-size: 26rpx;
  color: #999;
  padding: 16rpx 0;
}
.btn-start {
  background: #FFB300;
  color: #fff;
  font-size: 28rpx;
  font-weight: 600;
  padding: 16rpx 40rpx;
  border-radius: 16rpx;
}
