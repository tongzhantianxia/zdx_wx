.improve-page {
  min-height: 100vh;
  background: #FFFEF5;
  padding-bottom: calc(200rpx + env(safe-area-inset-bottom));
}

/* ==================== 自定义导航栏 ==================== */
.nav-bar {
  background-color: #FFFFFF;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
  position: sticky;
  top: 0;
  z-index: 100;
}

.nav-content {
  height: 88rpx;
  padding: 0 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.nav-logo {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.nav-duck {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background-color: #FFF9E6;
  border: 3rpx solid #FFB800;
}

.nav-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #2D2D2D;
  letter-spacing: 2rpx;
}

.capsule-placeholder {
  width: 174rpx;
  height: 64rpx;
  border-radius: 32rpx;
  border: 2rpx solid #EDEDEE;
  opacity: 0;
}

/* ==================== 主体内容 ==================== */
.guide-section {
  text-align: center;
  padding: 40rpx 30rpx 30rpx;
}

.guide-icon-wrap {
  width: 100rpx;
  height: 100rpx;
  margin: 0 auto 20rpx;
}

.guide-icon {
  width: 100%;
  height: 100%;
}

.guide-title {
  display: block;
  font-size: 38rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 12rpx;
}

.guide-desc {
  display: block;
  font-size: 26rpx;
  color: #888;
  line-height: 1.6;
  padding: 0 40rpx;
}

.upload-section {
  margin: 0 30rpx 30rpx;
}

.upload-area {
  border: 4rpx dashed #D0C8B8;
  border-radius: 24rpx;
  padding: 80rpx 0;
  text-align: center;
  background: #FFFCF5;
}

.upload-icon {
  font-size: 80rpx;
  color: #FFB300;
  line-height: 1;
  margin-bottom: 12rpx;
}

.upload-text {
  display: block;
  font-size: 28rpx;
  color: #999;
}

.preview-area {
  border-radius: 24rpx;
  overflow: hidden;
  background: #fff;
  border: 3rpx solid #E8E0D0;
}

.preview-img {
  width: 100%;
  display: block;
}

.preview-actions {
  display: flex;
  padding: 20rpx;
  gap: 16rpx;
}

.preview-btn {
  flex: 1;
  text-align: center;
  padding: 18rpx 0;
  border-radius: 16rpx;
  font-size: 28rpx;
  background: #F5F0E5;
  color: #666;
}

.btn-analyze {
  background: #FFB300;
  color: #fff;
  font-weight: 600;
}

.analyzing-section {
  text-align: center;
  padding: 60rpx 0;
}

.analyzing-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 6rpx solid #F0ECE0;
  border-top-color: #FFB300;
  border-radius: 50%;
  margin: 0 auto 20rpx;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.analyzing-text {
  font-size: 28rpx;
  color: #888;
}

.result-section {
  margin: 0 30rpx 30rpx;
}

.result-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.result-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.result-count {
  font-size: 24rpx;
  color: #999;
}

.knowledge-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.knowledge-tag {
  background: #fff;
  border: 3rpx solid #E8E0D0;
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  min-width: 200rpx;
}

.tag-selected {
  border-color: #FFB300;
  background: #FFFCF0;
}

.tag-name {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 6rpx;
}

.tag-grade {
  display: block;
  font-size: 22rpx;
  color: #999;
}

.practice-action {
  margin-top: 30rpx;
}

.btn-practice {
  width: 100%;
  background: #FFB300;
  color: #fff;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 20rpx;
  padding: 24rpx 0;
  border: none;
}

.tips-section {
  margin: 20rpx 30rpx 0;
}

.tip-card {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx 24rpx;
  margin-bottom: 16rpx;
  border: 3rpx solid #E8E0D0;
}

.tip-icon {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: #FFB300;
  color: #fff;
  font-size: 26rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.tip-text {
  font-size: 28rpx;
  color: #555;
}
