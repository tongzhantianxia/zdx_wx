<view class="improve-page">

  <!-- 自定义导航栏 -->
  <view class="nav-bar" style="padding-top: {{statusBarHeight}}px;">
    <view class="nav-content">
      <view class="nav-logo">
        <image class="nav-duck" src="/images/duck-avatar.png" mode="aspectFit"></image>
        <text class="nav-title">出题鸭</text>
      </view>
      <view class="capsule-placeholder"></view>
    </view>
  </view>

  <!-- idle 状态 -->
  <block wx:if="{{pageState === 'idle'}}">
    <view class="page-header">
      <text class="page-title">拍照分析错题</text>
      <text class="page-desc">拍照后自动识别错题和未做的题，针对性练习</text>
    </view>

    <view class="upload-section">
      <view class="upload-area" bindtap="chooseImage">
        <view class="upload-icon">+</view>
        <text class="upload-text">拍照 / 选择图片</text>
      </view>
    </view>

    <view class="tips-section">
      <view class="tip-card">
        <text class="tip-icon">1</text>
        <text class="tip-text">拍下孩子的试卷或作业</text>
      </view>
      <view class="tip-card">
        <text class="tip-icon">2</text>
        <text class="tip-text">调整选区，框选题目区域</text>
      </view>
      <view class="tip-card">
        <text class="tip-icon">3</text>
        <text class="tip-text">自动识别错题，一键生成练习</text>
      </view>
    </view>
  </block>

  <!-- cropping 状态：裁剪选区 -->
  <block wx:if="{{pageState === 'cropping'}}">
    <view class="crop-section">
      <text class="crop-hint">拖动边框调整识别区域</text>
      <view class="crop-container" style="width:{{imgDisplay.width}}px;height:{{imgDisplay.height}}px;margin-left:{{imgDisplay.left}}px;">
        <image class="crop-img" src="{{imagePath}}" mode="scaleToFill" style="width:{{imgDisplay.width}}px;height:{{imgDisplay.height}}px;"></image>
        <!-- Overlay mask (4 dark regions around crop box) -->
        <view class="crop-mask crop-mask-top" style="height:{{cropBox.y}}px;"></view>
        <view class="crop-mask crop-mask-bottom" style="top:{{cropBox.y + cropBox.h}}px;height:{{imgDisplay.height - cropBox.y - cropBox.h}}px;"></view>
        <view class="crop-mask crop-mask-left" style="top:{{cropBox.y}}px;height:{{cropBox.h}}px;width:{{cropBox.x}}px;"></view>
        <view class="crop-mask crop-mask-right" style="top:{{cropBox.y}}px;height:{{cropBox.h}}px;left:{{cropBox.x + cropBox.w}}px;width:{{imgDisplay.width - cropBox.x - cropBox.w}}px;"></view>
        <!-- Crop box border -->
        <view class="crop-box" style="left:{{cropBox.x}}px;top:{{cropBox.y}}px;width:{{cropBox.w}}px;height:{{cropBox.h}}px;">
          <view class="crop-handle crop-handle-tl"></view>
          <view class="crop-handle crop-handle-tr"></view>
          <view class="crop-handle crop-handle-bl"></view>
          <view class="crop-handle crop-handle-br"></view>
        </view>
        <!-- Touch area (covers full image) -->
        <view class="crop-touch" catchtouchstart="onCropTouchStart" catchtouchmove="onCropTouchMove" catchtouchend="onCropTouchEnd"></view>
      </view>
      <view class="crop-actions">
        <button class="crop-btn-cancel" bindtap="retakePhoto">重选</button>
        <button class="crop-btn-confirm" bindtap="confirmCrop">确认选区</button>
      </view>
    </view>
  </block>

  <!-- uploading 状态 -->
  <block wx:if="{{pageState === 'uploading'}}">
    <view class="loading-section">
      <view class="progress-bar-wrap">
        <view class="progress-bar" style="width: {{uploadProgress}}%;"></view>
      </view>
      <text class="loading-text">正在上传图片... {{uploadProgress}}%</text>
    </view>
  </block>

  <!-- analyzing 状态：扫描动画 -->
  <block wx:if="{{pageState === 'analyzing'}}">
    <view class="scan-section">
      <view class="scan-wrap">
        <image class="scan-img" src="{{imagePath}}" mode="widthFix"></image>
        <view class="scan-overlay">
          <view class="scan-line"></view>
        </view>
      </view>
      <text class="scan-text">正在识别题目...</text>
    </view>
  </block>

  <!-- result 状态 -->
  <block wx:if="{{pageState === 'result'}}">

    <!-- 顶部提示 -->
    <view class="result-banner">
      <text class="banner-text">批改完成，共 {{totalCount}} 题，{{improveCount}} 题需要练习。</text>
    </view>

    <!-- 错题 Tab 栏 -->
    <view class="tab-bar-wrap">
      <scroll-view class="tab-scroll" scroll-x enhanced show-scrollbar="{{false}}" scroll-into-view="tab-{{activeTab}}">
        <view class="tab-inner">
          <view
            wx:for="{{questions}}"
            wx:key="index"
            id="tab-{{index}}"
            class="tab-item {{activeTab === index ? 'tab-active' : ''}}"
            bindtap="switchTab"
            data-tab="{{index}}">
            <text class="tab-label">题目{{item.index}}</text>
            <text class="tab-tag tab-tag-{{item.status}}">{{item.status === 'wrong' ? '错题' : '未答'}}</text>
          </view>
        </view>
      </scroll-view>
    </view>

    <!-- 当前题详情 -->
    <block wx:if="{{currentDetail}}">
      <view class="detail-content">

        <view class="detail-card">
          <text class="detail-label">题目截图</text>
          <view class="detail-img-wrap">
            <image class="detail-img" src="{{currentDetail.questionImage || imagePath}}" mode="widthFix" bindtap="previewQuestionImage"></image>
          </view>
        </view>

        <view class="detail-card">
          <text class="detail-label">题目内容</text>
          <text class="detail-text">{{currentDetail.content}}</text>
        </view>

        <view class="detail-row">
          <view class="detail-card detail-half">
            <text class="detail-label">知识点</text>
            <text class="detail-tag tag-knowledge">{{currentDetail.knowledgeName || currentDetail.knowledgePoint}}</text>
          </view>
          <view class="detail-card detail-half">
            <text class="detail-label">难度</text>
            <text class="detail-tag tag-diff-{{currentDetail.difficulty}}">
              {{currentDetail.difficulty === 'easy' ? '简单' : currentDetail.difficulty === 'medium' ? '中等' : '困难'}}
            </text>
          </view>
        </view>

        <block wx:if="{{currentDetail.hasGraphic && currentDetail.graphicDesc}}">
          <view class="detail-card">
            <text class="detail-label">图形描述</text>
            <text class="detail-text">{{currentDetail.graphicDesc}}</text>
          </view>
        </block>

      </view>
    </block>

    <!-- 底部操作栏 -->
    <view class="bottom-bar">
      <view class="bottom-inner">
        <text class="btn-retake" bindtap="retakePhoto">重拍</text>
        <button class="btn-generate {{!currentDetail ? 'btn-generate-disabled' : ''}}" bindtap="startTraining" disabled="{{!currentDetail}}">
          <text class="btn-generate-text">生成针对练习题</text>
        </button>
      </view>
    </view>

  </block>

  <!-- Hidden canvas for cropping & extraction -->
  <canvas type="2d" id="cropCanvas" style="position:fixed;left:-9999px;top:-9999px;width:{{canvasWidth}}px;height:{{canvasHeight}}px;"></canvas>

</view>
