<view class="improve-page">

  <!-- 自定义导航栏 -->
  <view class="nav-bar" style="padding-top: {{statusBarHeight}}px;">
    <view class="nav-content">
      <view class="nav-logo">
        <image class="nav-duck" src="/images/duck-avatar.png" mode="aspectFit"></image>
        <text class="nav-title">出题鸭</text>
      </view>
      <view class="capsule-placeholder"></view>
    </view>
  </view>

  <!-- 引导区 -->
  <view class="guide-section">
    <view class="guide-icon-wrap">
      <image class="guide-icon" src="/images/tab-improve-active.png" mode="aspectFit"></image>
    </view>
    <text class="guide-title">拍照分析错题</text>
    <text class="guide-desc">拍照或选择试卷图片，AI自动识别知识点，生成针对性练习题</text>
  </view>

  <!-- 拍照/选择区 -->
  <view class="upload-section">
    <view class="upload-area" bindtap="chooseImage" wx:if="{{!imagePath}}">
      <view class="upload-icon">+</view>
      <text class="upload-text">拍照 / 选择图片</text>
    </view>
    <view class="preview-area" wx:else>
      <image class="preview-img" src="{{imagePath}}" mode="widthFix"></image>
      <view class="preview-actions">
        <view class="preview-btn" bindtap="chooseImage">重新选择</view>
        <view class="preview-btn btn-analyze" bindtap="analyzeImage">开始分析</view>
      </view>
    </view>
  </view>

  <!-- 分析中状态 -->
  <view class="analyzing-section" wx:if="{{analyzing}}">
    <view class="analyzing-spinner"></view>
    <text class="analyzing-text">AI正在分析知识点...</text>
  </view>

  <!-- 分析结果 -->
  <view class="result-section" wx:if="{{analysisResult && !analyzing}}">
    <view class="result-header">
      <text class="result-title">识别到以下知识点</text>
      <text class="result-count">共{{analysisResult.length}}个</text>
    </view>
    <view class="knowledge-tags">
      <view
        class="knowledge-tag {{selectedPoints[index] ? 'tag-selected' : ''}}"
        wx:for="{{analysisResult}}"
        wx:key="id"
        bindtap="togglePoint"
        data-index="{{index}}">
        <text class="tag-name">{{item.name}}</text>
        <text class="tag-grade">{{item.grade}}</text>
      </view>
    </view>

    <view class="practice-action" wx:if="{{hasSelected}}">
      <button class="btn-practice" bindtap="startPractice">
        针对选中知识点生成练习题
      </button>
    </view>
  </view>

  <!-- 空状态提示 -->
  <view class="tips-section" wx:if="{{!imagePath && !analyzing && !analysisResult}}">
    <view class="tip-card">
      <text class="tip-icon">1</text>
      <text class="tip-text">拍下孩子的错题或试卷</text>
    </view>
    <view class="tip-card">
      <text class="tip-icon">2</text>
      <text class="tip-text">AI自动识别涉及的知识点</text>
    </view>
    <view class="tip-card">
      <text class="tip-icon">3</text>
      <text class="tip-text">一键生成同类型练习题</text>
    </view>
  </view>

</view>
