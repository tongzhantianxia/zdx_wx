<!--pages/result/result.wxml-->
<view class="result-page">

  <!-- 背景装饰 -->
  <view class="bg-circle bg-c1"></view>
  <view class="bg-circle bg-c2"></view>

  <!-- 鸭子庆祝区 -->
  <view class="celebration-zone">
    <view class="star-float star-l">⭐</view>
    <view class="star-float star-r">🌟</view>
    <view class="duck-wrap">
      <image class="result-duck" src="/images/duck-avatar.png" mode="aspectFit"></image>
    </view>
    <view class="confetti-row">
      <text wx:for="{{[1,2,3,4,5]}}" wx:key="*this" class="confetti">🎉</text>
    </view>
  </view>

  <!-- 完成标题 -->
  <view class="title-zone">
    <text class="result-title">练习完成！</text>
    <text class="result-subtitle">今天又进步了一点点 🐥</text>
  </view>

  <!-- 统计卡片 -->
  <view class="stats-row">
    <view class="stat-card">
      <text class="stat-num">{{questionCount}}</text>
      <text class="stat-unit">道题</text>
      <text class="stat-desc">本次练习</text>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-card stat-card-main">
      <text class="stat-knowledge">{{knowledgeName}}</text>
      <text class="stat-desc">练习知识点</text>
    </view>
  </view>

  <!-- 金鸭子收集进度 -->
  <view class="duck-summary" wx:if="{{duckDelta}}">
    <view class="duck-progress-card">
      <view class="duck-progress-header">
        <text class="duck-progress-title">金鸭子收集进度</text>
        <text class="duck-progress-total">共 {{totalDucks}} 只</text>
      </view>
      <view class="duck-progress-bar">
        <view class="duck-progress-fill" style="width: {{duckPercent}}%"></view>
        <view class="duck-progress-target" style="left: {{targetPercent}}%">
          <text class="target-label">🏆</text>
        </view>
      </view>
      <view class="duck-progress-info">
        <text class="duck-earned">+{{duckDelta.earned}} 本次获得</text>
        <text class="duck-target-hint" wx:if="{{!isGoldenDuck}}">再对 {{remainForGolden}} 只解锁金鸭</text>
        <text class="duck-golden-ready" wx:if="{{isGoldenDuck}}">即将进化金鸭！</text>
      </view>
    </view>
    <!-- 连胜进度 -->
    <view class="streak-bar">
      <text class="streak-label">连胜加成</text>
      <view class="streak-dots">
        <view wx:for="{{[0,1,2,3,4]}}" wx:key="*this" class="streak-dot {{item < consecutivePerfect ? 'streak-dot-active' : ''}}"></view>
      </view>
      <text class="streak-count">{{consecutivePerfect}}/5</text>
    </view>
  </view>

  <!-- 鼓励语 -->
  <view class="encourage-card">
    <text class="encourage-icon">💪</text>
    <text class="encourage-text">{{encouragement}}</text>
  </view>

  <!-- 错题回顾 -->
  <view class="review-section" wx:if="{{wrongAnswers && wrongAnswers.length > 0}}">
    <view class="review-header">
      <text class="review-title">错题回顾</text>
      <text class="review-count">{{wrongAnswers.length}}道</text>
    </view>
    <view class="review-card" wx:for="{{wrongAnswers}}" wx:key="index">
      <view class="review-q-body">
        <math-text blocks="{{item.contentBlocks}}" />
      </view>
      <chart-renderer wx:if="{{item.chartData}}" chartData="{{item.chartData}}" />
      <view class="review-answers">
        <view class="review-row review-wrong">
          <text class="review-label">你的答案：</text>
          <text class="review-val">{{item.userAnswer}}</text>
        </view>
        <view class="review-row review-correct">
          <text class="review-label">正确答案：</text>
          <text class="review-val">{{item.correctAnswer}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 操作按钮区 -->
  <view class="action-zone">
    <button class="btn-continue" bindtap="handleContinue">
      <text>🔄 继续练习</text>
    </button>
    <button class="btn-change" bindtap="handleChange">
      换个知识点
    </button>
    <button class="btn-share" open-type="share">
      分享给好朋友 📣
    </button>
  </view>

</view>

<!-- 金色鸭子动画 -->
<duck-animation id="duckAnimResult"></duck-animation>
