<!--pages/result/result.wxml-->
<view class="container">
  <!-- 完成图标 -->
  <view class="celebration">
    <text class="emoji">🎉</text>
  </view>

  <!-- 标题 -->
  <view class="title-section">
    <text class="title">练习完成！</text>
  </view>

  <!-- 完成信息卡片 -->
  <view class="info-card">
    <view class="info-row">
      <text class="info-label">本次练习</text>
      <text class="info-value">{{questionCount}}道题</text>
    </view>
    <view class="info-row">
      <text class="info-label">知识点</text>
      <text class="info-value">{{knowledgeName}}</text>
    </view>
  </view>

  <!-- 鼓励语 -->
  <view class="encouragement">
    <text class="encouragement-text">{{encouragement}}</text>
  </view>

  <!-- 操作按钮 -->
  <view class="action-buttons">
    <button class="btn btn-primary" bindtap="handleContinue">
      继续练习这个知识点
    </button>
    <button class="btn btn-secondary" bindtap="handleChange">
      换个知识点练习
    </button>
    <button class="btn btn-share" open-type="share">
      分享给其他家长
    </button>
  </view>
</view>
