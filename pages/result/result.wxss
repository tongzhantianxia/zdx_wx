/* pages/result/result.wxss */
.result-page {
  min-height: 100vh;
  padding-bottom: calc(200rpx + env(safe-area-inset-bottom));
}

/* 结果概览 */
.result-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: var(--spacing-xl) 0;
  background: linear-gradient(180deg, #4A90E2 0%, #6BA3E8 100%);
  border-radius: 0 0 var(--radius-lg) var(--radius-lg);
  margin-bottom: var(--spacing-lg);
}

.score-circle {
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  background-color: #FFFFFF;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: var(--spacing-md);
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.15);
}

.score-number {
  font-size: 64rpx;
  font-weight: 700;
  color: var(--primary-color);
}

.score-unit {
  font-size: 28rpx;
  color: var(--primary-color);
  margin-left: 4rpx;
}

.score-circle.excellent .score-number,
.score-circle.excellent .score-unit {
  color: var(--success-color);
}

.score-circle.good .score-number,
.score-circle.good .score-unit {
  color: var(--primary-color);
}

.score-circle.normal .score-number,
.score-circle.normal .score-unit {
  color: var(--warning-color);
}

.score-circle.poor .score-number,
.score-circle.poor .score-unit {
  color: var(--error-color);
}

.score-label {
  font-size: 28rpx;
  color: #FFFFFF;
}

/* 统计信息 */
.stats-section {
  display: flex;
  justify-content: space-around;
  align-items: center;
  background-color: var(--bg-secondary);
  border-radius: var(--radius-lg);
  padding: var(--spacing-lg);
  margin: 0 var(--spacing-md) var(--spacing-lg);
  box-shadow: 0 4rpx 12rpx var(--shadow-color);
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-value {
  font-size: 48rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.stat-label {
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-top: 8rpx;
}

.stat-divider {
  width: 2rpx;
  height: 60rpx;
  background-color: var(--border-color);
}

/* 评语 */
.comment-section {
  margin: 0 var(--spacing-md) var(--spacing-lg);
  text-align: center;
}

.comment-text {
  font-size: 30rpx;
  color: var(--text-secondary);
  line-height: 1.6;
}

/* 错题列表 */
.wrong-list-section {
  margin: 0 var(--spacing-md) var(--spacing-lg);
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: var(--spacing-md);
}

.wrong-item {
  margin-bottom: var(--spacing-md);
}

.wrong-question {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: var(--spacing-md);
}

.wrong-answers {
  background-color: var(--bg-primary);
  border-radius: var(--radius-md);
  padding: var(--spacing-md);
  margin-bottom: var(--spacing-md);
}

.answer-row {
  display: flex;
  align-items: center;
  margin-bottom: 8rpx;
}

.answer-row:last-child {
  margin-bottom: 0;
}

.answer-label {
  font-size: 26rpx;
  color: var(--text-secondary);
  width: 140rpx;
}

.answer-value {
  font-size: 28rpx;
  font-weight: 600;
}

.answer-value.wrong {
  color: var(--error-color);
}

.answer-value.correct {
  color: var(--success-color);
}

.wrong-actions {
  padding-top: var(--spacing-sm);
  border-top: 2rpx solid var(--border-color);
}

.wrong-time {
  font-size: 24rpx;
  color: var(--text-placeholder);
}

.btn-small {
  font-size: 24rpx;
  padding: 8rpx 24rpx;
  border-radius: var(--radius-round);
  border: none;
}

.btn-review {
  background-color: rgba(74, 144, 226, 0.1);
  color: var(--primary-color);
}

/* 操作按钮 */
.action-section {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: var(--spacing-md);
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
  background-color: var(--bg-secondary);
  box-shadow: 0 -4rpx 12rpx var(--shadow-color);
}

.retry-btn {
  margin-bottom: var(--spacing-sm);
}

.home-btn {
  width: 100%;
}
