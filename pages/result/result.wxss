/* pages/result/result.wxss */

.result-page {
  min-height: 100vh;
  background-color: var(--bg-page);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: calc(80rpx + env(safe-area-inset-top)) 32rpx calc(60rpx + env(safe-area-inset-bottom));
  position: relative;
  overflow: hidden;
}

/* ==================== 背景装饰 ==================== */
.bg-circle {
  position: absolute;
  border-radius: 50%;
  z-index: 0;
  pointer-events: none;
}

.bg-c1 {
  width: 400rpx;
  height: 400rpx;
  background: radial-gradient(circle, rgba(255, 216, 77, 0.25) 0%, transparent 70%);
  top: -100rpx;
  right: -100rpx;
}

.bg-c2 {
  width: 320rpx;
  height: 320rpx;
  background: radial-gradient(circle, rgba(75, 191, 255, 0.20) 0%, transparent 70%);
  bottom: 100rpx;
  left: -80rpx;
}

/* ==================== 庆祝区 ==================== */
.celebration-zone {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 32rpx;
}

.duck-wrap {
  width: 200rpx;
  height: 200rpx;
  background: linear-gradient(135deg, var(--yellow-bg), #EBF7FF);
  border-radius: 50%;
  border: 6rpx solid var(--yellow);
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  box-shadow: 0 12rpx 40rpx rgba(255, 184, 0, 0.3);
  animation: duck-bounce 2.5s ease-in-out infinite;
}

@keyframes duck-bounce {
  0%, 100% { transform: translateY(0) rotate(0deg); }
  25% { transform: translateY(-16rpx) rotate(4deg); }
  75% { transform: translateY(-8rpx) rotate(-2deg); }
}

.result-duck {
  width: 180rpx;
  height: 180rpx;
}

.star-float {
  position: absolute;
  font-size: 48rpx;
  animation: star-pop 2s ease-in-out infinite;
}

.star-l {
  top: 20rpx;
  left: -20rpx;
  animation-delay: 0.3s;
}

.star-r {
  top: 60rpx;
  right: -30rpx;
  animation-delay: 1s;
}

@keyframes star-pop {
  0%, 100% { transform: scale(0.8) rotate(-10deg); opacity: 0.6; }
  50% { transform: scale(1.2) rotate(10deg); opacity: 1; }
}

.confetti-row {
  display: flex;
  gap: 16rpx;
  margin-top: 20rpx;
}

.confetti {
  font-size: 32rpx;
  animation: confetti-fall 1.5s ease-in-out infinite;
}

.confetti:nth-child(1) { animation-delay: 0s; }
.confetti:nth-child(2) { animation-delay: 0.2s; }
.confetti:nth-child(3) { animation-delay: 0.4s; }
.confetti:nth-child(4) { animation-delay: 0.6s; }
.confetti:nth-child(5) { animation-delay: 0.8s; }

@keyframes confetti-fall {
  0%, 100% { transform: translateY(0); opacity: 0.7; }
  50% { transform: translateY(-12rpx); opacity: 1; }
}

/* ==================== 标题 ==================== */
.title-zone {
  text-align: center;
  margin-bottom: 40rpx;
  z-index: 1;
}

.result-title {
  display: block;
  font-size: 52rpx;
  font-weight: 900;
  color: var(--text-main);
  letter-spacing: 4rpx;
  margin-bottom: 12rpx;
}

.result-subtitle {
  display: block;
  font-size: 28rpx;
  color: var(--text-sub);
}

/* ==================== 统计卡片 ==================== */
.stats-row {
  width: 100%;
  background-color: #FFFFFF;
  border-radius: var(--radius-xl);
  padding: 32rpx 24rpx;
  display: flex;
  align-items: center;
  box-shadow: var(--shadow-md);
  margin-bottom: 24rpx;
  z-index: 1;
}

.stat-card {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
}

.stat-card-main {
  flex: 1.5;
}

.stat-num {
  font-size: 64rpx;
  font-weight: 900;
  color: var(--yellow);
  line-height: 1;
}

.stat-unit {
  font-size: 26rpx;
  color: var(--text-sub);
  margin-top: -8rpx;
}

.stat-knowledge {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text-main);
  text-align: center;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.stat-desc {
  font-size: 22rpx;
  color: var(--text-hint);
  letter-spacing: 1rpx;
}

.stat-divider {
  width: 2rpx;
  height: 80rpx;
  background-color: var(--border-light);
  margin: 0 16rpx;
}

/* ==================== 鼓励语 ==================== */
.encourage-card {
  width: 100%;
  background: linear-gradient(135deg, var(--yellow-light) 0%, var(--yellow) 100%);
  border-radius: var(--radius-xl);
  padding: 32rpx 36rpx;
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 40rpx;
  z-index: 1;
  box-shadow: var(--shadow-yellow);
}

.encourage-icon {
  font-size: 52rpx;
  flex-shrink: 0;
}

.encourage-text {
  font-size: 30rpx;
  color: #FFFFFF;
  font-weight: 600;
  line-height: 1.6;
  flex: 1;
}

/* ==================== 错题回顾 ==================== */
.review-section {
  margin: 0 24rpx 24rpx;
}

.review-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.review-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text-main);
}

.review-count {
  font-size: 24rpx;
  color: var(--text-sub);
}

.review-card {
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.review-q-body {
  font-size: 30rpx;
  color: var(--text-main);
  line-height: 1.7;
  margin-bottom: 12rpx;
}

.review-answers {
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #f0f0f0;
}

.review-row {
  display: flex;
  align-items: center;
  margin-bottom: 8rpx;
}

.review-label {
  font-size: 26rpx;
  color: var(--text-sub);
  flex-shrink: 0;
}

.review-val {
  font-size: 26rpx;
  font-weight: 600;
  margin-left: 8rpx;
}

.review-wrong .review-val {
  color: var(--error);
  text-decoration: line-through;
}

.review-correct .review-val {
  color: var(--success);
}

/* ==================== 操作按钮 ==================== */
.action-zone {
  width: 100%;
  z-index: 1;
  margin-top: auto;
}

.btn-continue {
  width: 100%;
  height: 96rpx;
  border-radius: var(--radius-round);
  background: linear-gradient(135deg, var(--yellow-light), var(--yellow));
  color: #FFFFFF;
  font-size: 30rpx;
  font-weight: 700;
  border: none;
  box-shadow: var(--shadow-yellow);
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-continue::after { border: none; }
.btn-continue:active { transform: scale(0.97); }

.btn-change {
  width: 100%;
  height: 96rpx;
  border-radius: var(--radius-round);
  background-color: #FFFFFF;
  color: var(--blue);
  font-size: 30rpx;
  font-weight: 600;
  border: 2rpx solid var(--blue);
  box-shadow: var(--shadow-blue);
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-change::after { border: none; }
.btn-change:active { background-color: var(--blue-bg); transform: scale(0.97); }

.btn-share {
  width: 100%;
  height: 88rpx;
  border-radius: var(--radius-round);
  background-color: var(--bg-section);
  color: var(--text-sub);
  font-size: 28rpx;
  font-weight: 500;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-share::after { border: none; }

/* ==================== 鸭子摘要 ==================== */
.duck-summary {
  width: 100%;
  background-color: #FFFFFF;
  border-radius: var(--radius-xl);
  padding: 24rpx 32rpx;
  box-shadow: var(--shadow-sm);
  margin-bottom: 24rpx;
  z-index: 1;
}

.duck-summary-row {
  display: flex;
  align-items: center;
  gap: 24rpx;
  margin-bottom: 16rpx;
}

.duck-summary-item {
  font-size: 28rpx;
  font-weight: 600;
  padding: 6rpx 20rpx;
  border-radius: var(--radius-round);
}

.duck-hatched {
  background-color: #E8F8E8;
  color: var(--success);
}

.duck-died {
  background-color: #FFF1F0;
  color: var(--error);
}

.streak-bar {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.streak-label {
  font-size: 24rpx;
  color: var(--text-sub);
  flex-shrink: 0;
}

.streak-dots {
  display: flex;
  gap: 10rpx;
  flex: 1;
}

.streak-dot {
  width: 28rpx;
  height: 28rpx;
  border-radius: 50%;
  background-color: var(--border-light);
  border: 2rpx solid var(--border);
}

.streak-dot-active {
  background: linear-gradient(135deg, #FFD700, #FFA000);
  border-color: #FFA000;
  box-shadow: 0 2rpx 8rpx rgba(255, 168, 0, 0.4);
}

.streak-count {
  font-size: 24rpx;
  color: var(--text-sub);
  font-weight: 600;
  flex-shrink: 0;
}

