/* pages/result/result.wxss */

.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #E8F4FD 0%, #FFFFFF 50%);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 40rpx 60rpx;
}

/* 完成图标 */
.celebration {
  margin-bottom: 32rpx;
}

.emoji {
  font-size: 120rpx;
}

/* 标题 */
.title-section {
  margin-bottom: 48rpx;
}

.title {
  font-size: 48rpx;
  font-weight: 700;
  color: #333333;
}

/* 完成信息卡片 */
.info-card {
  width: 100%;
  background-color: #FFFFFF;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
}

.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
}

.info-row:not(:last-child) {
  border-bottom: 1rpx solid #F0F0F0;
}

.info-label {
  font-size: 28rpx;
  color: #999999;
}

.info-value {
  font-size: 28rpx;
  color: #333333;
  font-weight: 500;
}

/* 鼓励语 */
.encouragement {
  width: 100%;
  background: linear-gradient(135deg, #4A90E2 0%, #6BA3E8 100%);
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 48rpx;
  text-align: center;
}

.encouragement-text {
  font-size: 32rpx;
  color: #FFFFFF;
  font-weight: 500;
  line-height: 1.5;
}

/* 操作按钮 */
.action-buttons {
  width: 100%;
  margin-top: auto;
}

.btn {
  width: 100%;
  height: 96rpx;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
  border: none;
}

.btn::after {
  border: none;
}

.btn-primary {
  background: linear-gradient(135deg, #4A90E2 0%, #6BA3E8 100%);
  color: #FFFFFF;
}

.btn-secondary {
  background-color: #FFFFFF;
  color: #4A90E2;
  border: 2rpx solid #4A90E2;
}

.btn-share {
  background-color: #F5F7FA;
  color: #666666;
}

.btn-share::after {
  border: none;
}
