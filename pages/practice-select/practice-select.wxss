/* pages/practice-select/practice-select.wxss */

/* ==================== 页面容器 ==================== */
.page {
  min-height: 100vh;
  background-color: var(--bg-page);
  padding-bottom: calc(160rpx + env(safe-area-inset-bottom));
}

/* ==================== 自定义导航栏 ==================== */
.nav-bar {
  background-color: #FFFFFF;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
  position: sticky;
  top: 0;
  z-index: 100;
}

.nav-content {
  height: 88rpx;
  padding: 0 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.nav-logo {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.nav-duck {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background-color: var(--yellow-bg);
  border: 3rpx solid var(--yellow);
}

.nav-title {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--text-main);
  letter-spacing: 2rpx;
}

/* 胶囊按钮占位（右侧 87px × 32px 胶囊区域） */
.capsule-placeholder {
  width: 174rpx;
  height: 64rpx;
  border-radius: 32rpx;
  border: 2rpx solid var(--border);
  opacity: 0;
}

/* ==================== 品牌 Hero 区 ==================== */
.hero-section {
  margin: 20rpx 24rpx 0;
  background: linear-gradient(135deg, #FFF9E0 0%, #EBF7FF 100%);
  border-radius: 28rpx;
  padding: 36rpx 32rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  position: relative;
  overflow: hidden;
  min-height: 180rpx;
}

.hero-left {
  flex: 1;
  z-index: 2;
}

.hero-title {
  display: block;
  font-size: 64rpx;
  font-weight: 900;
  color: var(--yellow);
  letter-spacing: 4rpx;
  line-height: 1.1;
  margin-bottom: 12rpx;
  text-shadow: 0 4rpx 12rpx rgba(255, 184, 0, 0.25);
}

.hero-subtitle {
  display: block;
  font-size: 24rpx;
  color: var(--text-sub);
  line-height: 1.6;
}

.hero-right {
  width: 160rpx;
  height: 160rpx;
  flex-shrink: 0;
  z-index: 2;
  margin-left: 16rpx;
  animation: duck-float 3s ease-in-out infinite;
}

@keyframes duck-float {
  0% { transform: translateY(0); }
  50% { transform: translateY(-10rpx); }
  100% { transform: translateY(0); }
}

.hero-duck {
  width: 100%;
  height: 100%;
}

/* 装饰云朵 */
.cloud {
  position: absolute;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.5);
  z-index: 1;
}

.cloud-1 {
  width: 120rpx;
  height: 60rpx;
  top: 24rpx;
  right: 180rpx;
}

.cloud-2 {
  width: 80rpx;
  height: 40rpx;
  bottom: 32rpx;
  left: 200rpx;
}

/* ==================== 主体区域 ==================== */
.main-body {
  padding: 0 24rpx;
  margin-top: 24rpx;
}

/* ==================== 区块通用 ==================== */
.section-block {
  margin-bottom: 24rpx;
}

.section-label {
  display: block;
  font-size: 24rpx;
  color: var(--text-hint);
  margin-bottom: 16rpx;
  padding-left: 4rpx;
}

/* ==================== 年级横滑选择 ==================== */
.grade-scroll {
  width: 100%;
}

.grade-list {
  display: flex;
  gap: 16rpx;
  padding: 4rpx 4rpx 12rpx;
  white-space: nowrap;
}

.grade-btn {
  flex-shrink: 0;
  display: inline-flex;
  align-items: center;
  gap: 6rpx;
  height: 72rpx;
  padding: 0 28rpx;
  border-radius: var(--radius-round);
  border: 2rpx solid var(--border);
  background-color: #FFFFFF;
  font-size: 28rpx;
  color: var(--text-sub);
  font-weight: 500;
  box-shadow: var(--shadow-sm);
  transition: all var(--ease);
}

.grade-btn.grade-active {
  background-color: var(--yellow);
  border-color: var(--yellow);
  color: #FFFFFF;
  font-weight: 700;
  box-shadow: var(--shadow-yellow);
  transform: translateY(-2rpx);
}

.grade-duck-icon {
  width: 28rpx;
  height: 28rpx;
  border-radius: 50%;
}

.grade-text {
  line-height: 1;
}

/* ==================== 上下册选择 ==================== */
.semester-group {
  display: flex;
  gap: 20rpx;
}

.semester-btn {
  flex: 1;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: var(--radius-lg);
  border: 2rpx solid var(--border);
  background-color: #FFFFFF;
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-sub);
  box-shadow: var(--shadow-sm);
  transition: all var(--ease);
}

.semester-btn.semester-active {
  background-color: var(--blue);
  border-color: var(--blue);
  color: #FFFFFF;
  box-shadow: var(--shadow-blue);
}

.semester-check {
  font-weight: 700;
}

/* ==================== 知识点折叠面板 ==================== */
.accordion-wrap {
  background-color: #FFFFFF;
  border-radius: var(--radius-lg);
  overflow: hidden;
  box-shadow: var(--shadow-sm);
}

.chapter-panel {
  border-bottom: 1rpx solid var(--border-light);
}

.chapter-panel:last-child {
  border-bottom: none;
}

.chapter-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 28rpx;
  background-color: var(--yellow-pale);
  transition: background-color var(--ease);
}

.chapter-header.chapter-open {
  background-color: var(--yellow-bg);
  border-bottom: 1rpx solid rgba(255, 184, 0, 0.15);
}

.chapter-title {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text-main);
}

.chapter-arrow {
  font-size: 28rpx;
  color: var(--text-hint);
  font-weight: 300;
  line-height: 1;
}

.chapter-body {
  background-color: #FFFFFF;
}

.knowledge-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 28rpx;
  border-bottom: 1rpx solid var(--border-light);
  transition: background-color var(--ease);
}

.knowledge-row:last-child {
  border-bottom: none;
}

.knowledge-row.knowledge-active {
  background-color: var(--yellow-pale);
  border-left: 6rpx solid var(--yellow);
  padding-left: 22rpx;
}

.knowledge-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex: 1;
}

/* 圆形勾选框 */
.check-circle {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  border: 2rpx solid var(--border);
  background-color: #FFFFFF;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  transition: all var(--ease);
}

.check-circle.checked {
  background-color: var(--yellow);
  border-color: var(--yellow);
  box-shadow: 0 2rpx 8rpx rgba(255, 184, 0, 0.4);
}

.check-mark {
  font-size: 24rpx;
  color: #FFFFFF;
  font-weight: 700;
  line-height: 1;
}

.knowledge-name {
  font-size: 28rpx;
  color: var(--text-body);
}

.knowledge-row.knowledge-active .knowledge-name {
  color: var(--text-main);
  font-weight: 600;
}

/* 难度标签 */
.diff-badge {
  font-size: 22rpx;
  padding: 6rpx 18rpx;
  border-radius: var(--radius-round);
  font-weight: 500;
  flex-shrink: 0;
}

.diff-1 {
  background-color: var(--success-light);
  color: var(--success);
}

.diff-2 {
  background-color: var(--warning-bg);
  color: var(--warning);
}

.diff-3 {
  background-color: var(--error-bg);
  color: var(--error);
}

/* ==================== 题量选择 ==================== */
.count-group {
  display: flex;
  gap: 16rpx;
}

.count-btn {
  flex: 1;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: var(--radius-md);
  border: 2rpx solid var(--border);
  background-color: #FFFFFF;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-sub);
  box-shadow: var(--shadow-sm);
  transition: all var(--ease);
}

.count-btn.count-active {
  background-color: var(--yellow);
  border-color: var(--yellow);
  color: #FFFFFF;
  font-weight: 700;
  box-shadow: var(--shadow-yellow);
  transform: translateY(-2rpx);
}

/* ==================== 底部生成按钮 ==================== */
.footer-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: #FFFFFF;
  border-top: 1rpx solid var(--border-light);
  padding: 20rpx 32rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.06);
  z-index: 50;
}

.footer-inner {
  position: relative;
}

.generate-btn {
  width: 100%;
  height: 100rpx;
  border-radius: var(--radius-round);
  background: linear-gradient(135deg, var(--yellow-light) 0%, var(--yellow) 100%);
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: var(--shadow-yellow);
  transition: transform var(--ease);
  position: relative;
}

.generate-btn:active {
  transform: scale(0.97);
}

.generate-btn::after {
  border: none;
}

.generate-btn.generate-disabled {
  background: #E8E8E8;
  box-shadow: none;
}

.generate-text {
  font-size: 34rpx;
  font-weight: 700;
  color: #FFFFFF;
  letter-spacing: 2rpx;
}

.generate-btn.generate-disabled .generate-text {
  color: #AAAAAA;
}
