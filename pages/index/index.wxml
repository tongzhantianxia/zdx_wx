<!--pages/index/index.wxml-->
<view class="container">
  <view class="bg-orb orb-left"></view>
  <view class="bg-orb orb-right"></view>
  <!-- 顶部标题区域 -->
  <view class="header">
    <view class="header-content">
      <view class="title-group">
        <text class="badge">AI STUDY LAB</text>
        <text class="title">出题鸭</text>
        <text class="subtitle">聚焦薄弱知识点，沉浸式闯关提分</text>
      </view>
      <view class="mascot-box">
        <image class="mascot-img" src="/images/duck-avatar.png" mode="aspectFit"></image>
      </view>
    </view>
  </view>

  <!-- 主体选择区域 -->
  <view class="main-content">
    <!-- 学期选择 -->
    <view class="select-card">
      <view class="card-header">
        <text class="card-title">选择学期</text>
      </view>
      <view class="tab-group">
        <view
          class="tab-item {{selectedSemester === 'upper' ? 'active' : ''}}"
          bindtap="handleSemesterChange"
          data-semester="upper">
          五年级上册
        </view>
        <view
          class="tab-item {{selectedSemester === 'lower' ? 'active' : ''}}"
          bindtap="handleSemesterChange"
          data-semester="lower">
          五年级下册
        </view>
      </view>
    </view>

    <!-- 知识点选择 -->
    <view class="select-card">
      <view class="card-header">
        <text class="card-title">选择知识点</text>
        <text class="card-hint" wx:if="{{selectedKnowledge}}">已选: {{selectedKnowledge.name}}</text>
      </view>
      <scroll-view class="knowledge-list" scroll-y enhanced show-scrollbar="{{false}}">
        <view
          class="knowledge-group"
          wx:for="{{knowledgeList}}"
          wx:key="id"
          wx:for-item="chapter">
          <view class="group-title">第{{chapter.unit}}单元 {{chapter.name}}</view>
          <view
            class="knowledge-item {{selectedKnowledge && selectedKnowledge.id === item.id ? 'active' : ''}}"
            wx:for="{{chapter.knowledges}}"
            wx:key="id"
            bindtap="handleKnowledgeSelect"
            data-item="{{item}}"
            data-chapter="{{chapter}}">
            <view class="knowledge-name">{{item.name}}</view>
            <view class="knowledge-difficulty">
              <text class="diff-tag diff-{{item.difficulty_range[0]}}">
                {{item.difficulty_range[0] === 1 ? '基础' : item.difficulty_range[0] === 2 ? '进阶' : '挑战'}}
              </text>
            </view>
          </view>
        </view>
      </scroll-view>
    </view>

    <!-- 题目数量 -->
    <view class="select-card">
      <view class="card-header">
        <text class="card-title">题目数量</text>
      </view>
      <view class="option-group">
        <view
          class="option-item {{selectedCount === 3 ? 'active' : ''}}"
          bindtap="handleCountChange"
          data-count="{{3}}">
          <text class="option-number">3</text>
          <text class="option-text">道题</text>
        </view>
        <view
          class="option-item {{selectedCount === 5 ? 'active' : ''}}"
          bindtap="handleCountChange"
          data-count="{{5}}">
          <text class="option-number">5</text>
          <text class="option-text">道题</text>
        </view>
        <view
          class="option-item {{selectedCount === 8 ? 'active' : ''}}"
          bindtap="handleCountChange"
          data-count="{{8}}">
          <text class="option-number">8</text>
          <text class="option-text">道题</text>
        </view>
      </view>
    </view>

    <!-- 难度选择 -->
    <view class="select-card">
      <view class="card-header">
        <text class="card-title">难度选择</text>
      </view>
      <view class="option-group">
        <view
          class="option-item difficulty-easy {{selectedDifficulty === 'easy' ? 'active' : ''}}"
          bindtap="handleDifficultyChange"
          data-difficulty="easy">
          简单
        </view>
        <view
          class="option-item difficulty-medium {{selectedDifficulty === 'medium' ? 'active' : ''}}"
          bindtap="handleDifficultyChange"
          data-difficulty="medium">
          中等
        </view>
        <view
          class="option-item difficulty-hard {{selectedDifficulty === 'hard' ? 'active' : ''}}"
          bindtap="handleDifficultyChange"
          data-difficulty="hard">
          困难
        </view>
      </view>
    </view>
  </view>

  <!-- 底部生成按钮 -->
  <view class="footer-btn">
    <button
      class="generate-btn {{!selectedKnowledge ? 'disabled' : ''}}"
      bindtap="handleGenerate"
      disabled="{{!selectedKnowledge}}">
      {{generating ? '生成中...' : '生成练习题'}}
    </button>
  </view>

  <!-- 加载提示 -->
  <view class="loading-mask" wx:if="{{generating}}">
    <view class="loading-content">
      <view class="loading-spinner"></view>
      <text class="loading-text">正在生成练习题...</text>
    </view>
  </view>
</view>
