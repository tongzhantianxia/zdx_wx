/* pages/index/index.wxss */

/* 页面容器 */
.container {
  min-height: 100vh;
  background: transparent;
  padding-top: calc(20rpx + env(safe-area-inset-top));
  padding-bottom: calc(220rpx + env(safe-area-inset-bottom));
  position: relative;
  overflow: visible;
}

/* 顶部标题区域 */
.header {
  margin: 0 24rpx 0;
  border-radius: 28rpx;
  background: linear-gradient(145deg, rgba(25, 38, 68, 0.86) 0%, rgba(20, 32, 57, 0.92) 100%);
  padding: 48rpx 40rpx;
  border: 1rpx solid rgba(135, 167, 245, 0.24);
  box-shadow: 0 20rpx 46rpx rgba(2, 6, 18, 0.5);
  position: relative;
  overflow: hidden;
}

.header-content {
  display: flex;
  justify-content: space-between;
  align-items: center;
  position: relative;
  z-index: 2;
}

.title-group {
  flex: 1;
}

.mascot-box {
  width: 140rpx;
  height: 140rpx;
  background: linear-gradient(135deg, rgba(88, 216, 255, 0.2) 0%, rgba(128, 255, 227, 0.1) 100%);
  border: 2rpx solid rgba(88, 216, 255, 0.4);
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 12rpx 24rpx rgba(88, 216, 255, 0.15), inset 0 4rpx 16rpx rgba(255, 255, 255, 0.1);
  transform: rotate(6deg);
  margin-left: 24rpx;
  animation: float-mascot 4s ease-in-out infinite;
}

@keyframes float-mascot {
  0% { transform: translateY(0) rotate(6deg); }
  50% { transform: translateY(-12rpx) rotate(2deg); }
  100% { transform: translateY(0) rotate(6deg); }
}

.mascot-emoji {
  font-size: 80rpx;
  filter: drop-shadow(0 4rpx 8rpx rgba(0, 0, 0, 0.3));
}

.badge {
  display: inline-block;
  padding: 8rpx 18rpx;
  background: rgba(88, 216, 255, 0.16);
  color: #80ffe3;
  border: 1rpx solid rgba(128, 255, 227, 0.42);
  border-radius: 999rpx;
  font-size: 20rpx;
  letter-spacing: 2rpx;
  margin-bottom: 18rpx;
}

.title {
  display: block;
  font-size: 52rpx;
  font-weight: 800;
  background: linear-gradient(135deg, #ffffff 0%, #80ffe3 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  letter-spacing: 4rpx;
  margin-bottom: 8rpx;
}

.subtitle {
  display: block;
  font-size: 28rpx;
  color: #b8c7ea;
  margin-top: 14rpx;
}

/* 主体内容区域 */
.main-content {
  padding: 24rpx 24rpx 0;
  position: relative;
  z-index: 2;
}

/* 选择卡片 */
.select-card {
  background-color: rgba(22, 31, 53, 0.9);
  border-radius: 24rpx;
  padding: 28rpx 24rpx;
  margin-bottom: 20rpx;
  border: 1rpx solid rgba(118, 155, 240, 0.23);
  box-shadow: 0 18rpx 38rpx rgba(3, 8, 20, 0.36);
  backdrop-filter: blur(10rpx);
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #f4f7ff;
}

.card-hint {
  font-size: 24rpx;
  color: #80ffe3;
}

/* 选项卡组 */
.tab-group {
  display: flex;
  background-color: rgba(8, 13, 27, 0.72);
  border-radius: 20rpx;
  padding: 8rpx;
  box-shadow: inset 0 4rpx 12rpx rgba(0, 0, 0, 0.2);
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  font-size: 28rpx;
  color: #9fb0da;
  border-radius: 16rpx;
  transition: all 0.3s ease;
  font-weight: 600;
}

.tab-item.active {
  background: linear-gradient(125deg, #2c83ff 0%, #58d8ff 100%);
  color: #081325;
  font-weight: 700;
  box-shadow: 0 8rpx 16rpx rgba(44, 131, 255, 0.2);
}

/* 知识点列表 */
.knowledge-list {
  max-height: 500rpx;
}

.knowledge-group {
  margin-bottom: 16rpx;
}

.group-title {
  font-size: 26rpx;
  color: #93a4cc;
  padding: 16rpx 0 12rpx;
  border-bottom: 1rpx solid #F0F0F0;
}

.knowledge-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 16rpx;
  margin-top: 8rpx;
  background-color: rgba(11, 18, 35, 0.85);
  border-radius: 12rpx;
  border: 1rpx solid rgba(118, 155, 240, 0.1);
  transition: all 0.2s ease;
}

.knowledge-item:active {
  background-color: rgba(19, 42, 87, 0.68);
}

.knowledge-item.active {
  background-color: rgba(27, 68, 132, 0.5);
  border-color: #58d8ff;
  box-shadow: 0 8rpx 24rpx rgba(44, 131, 255, 0.15);
}

.knowledge-name {
  font-size: 28rpx;
  color: #d8e2ff;
}

.knowledge-item.active .knowledge-name {
  color: #80ffe3;
  font-weight: 600;
}

.knowledge-difficulty {
  display: flex;
  align-items: center;
}

.diff-tag {
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.diff-tag.diff-1 {
  background-color: rgba(92, 245, 167, 0.14);
  color: #5cf5a7;
}

.diff-tag.diff-2 {
  background-color: rgba(255, 191, 97, 0.12);
  color: #ffbf61;
}

.diff-tag.diff-3 {
  background-color: rgba(255, 107, 142, 0.13);
  color: #ff6b8e;
}

/* 选项组 */
.option-group {
  display: flex;
  justify-content: space-between;
}

.option-item {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  margin: 0 8rpx;
  background-color: rgba(10, 18, 35, 0.86);
  border-radius: 20rpx;
  font-size: 28rpx;
  color: #9fb0da;
  border: 1rpx solid rgba(118, 155, 240, 0.1);
  transition: all 0.2s ease;
  font-weight: 600;
}

.option-item:first-child {
  margin-left: 0;
}

.option-item:last-child {
  margin-right: 0;
}

.option-item.active {
  background-color: rgba(28, 77, 156, 0.5);
  border-color: #58d8ff;
  color: #80ffe3;
  font-weight: 700;
  box-shadow: 0 8rpx 20rpx rgba(88, 216, 255, 0.15);
  transform: translateY(-2rpx);
}

.option-number {
  font-size: 40rpx;
  font-weight: 600;
}

.option-text {
  font-size: 24rpx;
  margin-left: 4rpx;
}

/* 难度颜色区分 */
.difficulty-easy.active {
  background-color: rgba(92, 245, 167, 0.2);
  border-color: #5cf5a7;
  color: #5cf5a7;
  box-shadow: 0 8rpx 20rpx rgba(92, 245, 167, 0.15);
}

.difficulty-medium.active {
  background-color: rgba(255, 191, 97, 0.2);
  border-color: #ffbf61;
  color: #ffbf61;
  box-shadow: 0 8rpx 20rpx rgba(255, 191, 97, 0.15);
}

.difficulty-hard.active {
  background-color: rgba(255, 107, 142, 0.2);
  border-color: #ff6b8e;
  color: #ff6b8e;
  box-shadow: 0 8rpx 20rpx rgba(255, 107, 142, 0.15);
}

/* 底部按钮 */
.footer-btn {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background-color: rgba(8, 14, 29, 0.9);
  border-top: 1rpx solid rgba(118, 155, 240, 0.24);
  box-shadow: 0 -6rpx 26rpx rgba(0, 0, 0, 0.36);
  z-index: 20;
}

.generate-btn {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #2c83ff 0%, #58d8ff 60%, #80ffe3 100%);
  color: #061222;
  font-size: 34rpx;
  font-weight: 700;
  letter-spacing: 4rpx;
  border-radius: 48rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 12rpx 32rpx rgba(44, 131, 255, 0.3);
  transition: transform 0.1s;
}

.generate-btn:active {
  transform: scale(0.96);
}

.generate-btn::after {
  border: none;
}

.generate-btn.disabled {
  background: #5a6786;
  color: #cdd9f6;
}

/* 加载遮罩 */
.loading-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.loading-content {
  background-color: #16203a;
  border: 1rpx solid rgba(118, 155, 240, 0.3);
  border-radius: 24rpx;
  padding: 48rpx 64rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.loading-spinner {
  width: 64rpx;
  height: 64rpx;
  border: 4rpx solid rgba(118, 155, 240, 0.24);
  border-top-color: #58d8ff;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

.loading-text {
  font-size: 28rpx;
  color: #d6e3ff;
  margin-top: 24rpx;
}

.bg-orb {
  position: absolute;
  border-radius: 50%;
  filter: blur(6rpx);
  z-index: 1;
}

.orb-left {
  width: 340rpx;
  height: 340rpx;
  top: -90rpx;
  left: -110rpx;
  background: radial-gradient(circle, rgba(76, 96, 255, 0.54) 0%, rgba(76, 96, 255, 0) 70%);
}

.orb-right {
  width: 280rpx;
  height: 280rpx;
  top: 220rpx;
  right: -100rpx;
  background: radial-gradient(circle, rgba(88, 216, 255, 0.45) 0%, rgba(88, 216, 255, 0) 70%);
}
